---
import Layout from '../layouts/Layout.astro';
import NewsletterSignupCard from '../components/NewsletterSignupCard.astro';
import { getCollection } from 'astro:content';

const videos = (await getCollection('videos')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const videoTiles = videos.map((video) => ({
  ...video,
  thumbnail: `https://img.youtube.com/vi/${video.data.videoId}/hqdefault.jpg`
}));
---

<Layout
  title="Fin Sanctuary Videos"
  description="Browse Fin Sanctuary videos in a tile layout with thumbnails, descriptions, and direct YouTube links."
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.08),rgba(243,239,238,0.55))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.14),rgba(2,6,23,0.95))]">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:py-12 xl:grid-cols-[minmax(0,1fr)_22rem] xl:items-end">
        <div>
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Video Library</div>
          <h1 class="mt-5 font-bold tracking-tight text-primary">Every Fin Sanctuary video in one clean tile library.</h1>
          <p class="mt-6 max-w-3xl text-slate-700 dark:text-slate-200">
            This page now works as the main video archive: each tile shows the video thumbnail, title, and description, then links straight to YouTube without adding unnecessary extra pages on the site.
          </p>
        </div>
        <div class="rounded-[2rem] border border-primary/10 bg-white/80 p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] backdrop-blur dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Current Focus</div>
          <ul class="mt-4 space-y-3 text-slate-700 dark:text-slate-300">
            <li>Each tile includes a thumbnail, title, description, and direct YouTube link.</li>
            <li>New uploads can be added quickly without building separate detail pages.</li>
            <li>The gallery can still feature a video, but the video library stays simple and direct.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {videoTiles.map((video) => (
          <article class="group overflow-hidden rounded-[1.75rem] border border-primary/10 bg-white shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] transition-transform hover:-translate-y-1 dark:border-white/8 dark:bg-slate-900">
            <a
              href={video.data.externalUrl}
              target="_blank"
              rel="noreferrer"
              class="block"
              data-track-click="video_outbound_click"
              data-track-location="videos-tile-thumbnail"
              data-track-label={video.data.title}
              data-track-category="video"
              data-track-destination={video.data.externalUrl}
            >
              <img
                src={video.thumbnail}
                alt={`${video.data.title} thumbnail`}
                class="aspect-video w-full object-cover"
                loading="lazy"
              />
            </a>
            <div class="p-7">
              <div class="flex items-center justify-between gap-3">
                <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">YouTube Video</div>
                {video.data.featured && (
                  <span class="rounded-full border border-primary/15 px-3 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-primary/80 dark:border-primary/25">
                    Featured
                  </span>
                )}
              </div>
              <h2 class="mt-4 font-semibold tracking-tight text-primary transition-colors group-hover:text-accent-1">{video.data.title}</h2>
              <p class="mt-3 text-slate-700 dark:text-slate-300">{video.data.description}</p>
              <a
                href={video.data.externalUrl}
                target="_blank"
                rel="noreferrer"
                class="mt-5 inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
                data-track-click="video_outbound_click"
                data-track-location="videos-tile-cta"
                data-track-label={video.data.title}
                data-track-category="video"
                data-track-destination={video.data.externalUrl}
              >
                Watch on YouTube
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
        <section class="rounded-[2rem] border border-primary/10 bg-white px-7 py-6 text-slate-600 dark:border-white/8 dark:bg-slate-900 dark:text-slate-300">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Next Step</div>
          <h2 class="mt-3 font-semibold tracking-tight text-primary">Use videos to move into guides and practical planning.</h2>
          <p class="mt-4">The video library works best when it points back into the educational side of the site. Watch on YouTube, then keep going with the guide library or the aquarium wizard if you are planning a setup.</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/guides" class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="media_next_step_click" data-track-location="videos-next-step" data-track-label="Browse Guides" data-track-category="guides" data-track-destination="/guides">Browse Guides</a>
            <a href="/wizard" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="media_next_step_click" data-track-location="videos-next-step" data-track-label="Use the Wizard" data-track-category="wizard" data-track-destination="/wizard">Use the Wizard</a>
          </div>
        </section>
        <NewsletterSignupCard
          interest="newsletter-videos-page"
          location="videos-page"
          description="Join the email list for new videos, new guides, and aquarium planning updates without having to keep checking the library manually."
          note="This is the easiest way to follow new uploads without having to keep checking the library manually."
        />
      </div>
    </section>
  </main>
</Layout>
