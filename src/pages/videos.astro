---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const videos = (await getCollection('videos')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const featuredVideo = videos.find((entry) => entry.data.featured) ?? videos[0];
---

<Layout
  title="Fin Sanctuary Videos"
  description="Browse dedicated Fin Sanctuary video pages with embedded YouTube playback, future notes, and aquarium media updates."
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.08),rgba(243,239,238,0.55))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.14),rgba(2,6,23,0.95))]">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:py-12 xl:grid-cols-[minmax(0,1fr)_22rem] xl:items-end">
        <div>
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Video Library</div>
          <h1 class="mt-5 font-bold tracking-tight text-primary">Dedicated pages for every Fin Sanctuary video.</h1>
          <p class="mt-6 max-w-3xl text-slate-700 dark:text-slate-200">
            This section gives every published video its own shareable page with embedded playback, room for future notes, and clean linking from guides, gallery features, and newsletters.
          </p>
        </div>
        <div class="rounded-[2rem] border border-primary/10 bg-white/80 p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] backdrop-blur dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Current Focus</div>
          <ul class="mt-4 space-y-3 text-slate-700 dark:text-slate-300">
            <li>Each video gets its own page instead of living only in the gallery.</li>
            <li>Future uploads can be linked directly from guides and product pages.</li>
            <li>The library is ready for notes, timestamps, and media summaries later.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10">
      {featuredVideo && (
        <section class="mb-10 rounded-[2rem] border border-primary/10 bg-white p-6 shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] dark:border-white/8 dark:bg-slate-900 md:p-8">
          <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-center">
            <div>
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Featured Video</div>
              <h2 class="mt-3 font-semibold tracking-tight text-primary">{featuredVideo.data.title}</h2>
              <p class="mt-4 text-slate-700 dark:text-slate-300">{featuredVideo.data.description}</p>
              <div class="mt-6 flex flex-wrap gap-3">
                <a
                  href={`/videos/${featuredVideo.id}`}
                  class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1"
                >
                  Open Video Page
                </a>
                <a
                  href={featuredVideo.data.externalUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
                >
                  Watch on YouTube
                </a>
              </div>
            </div>
            <div class="overflow-hidden rounded-[1.75rem] border border-primary/10 bg-light-bg/60 shadow-[0_20px_70px_-50px_rgba(1,133,174,0.45)] dark:border-white/8 dark:bg-slate-950/70">
              <div class="aspect-video">
                <iframe
                  class="h-full w-full"
                  src={`https://www.youtube.com/embed/${featuredVideo.data.videoId}`}
                  title={featuredVideo.data.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          </div>
        </section>
      )}

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {videos.map((video) => (
          <a href={`/videos/${video.id}`} class="group rounded-[1.75rem] border border-primary/10 bg-white p-7 shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] transition-transform hover:-translate-y-1 dark:border-white/8 dark:bg-slate-900">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">YouTube Video</div>
            <h2 class="mt-4 font-semibold tracking-tight text-primary transition-colors group-hover:text-accent-1">{video.data.title}</h2>
            <p class="mt-3 text-slate-700 dark:text-slate-300">{video.data.description}</p>
            <div class="mt-5 text-sm font-medium text-primary">Open page →</div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
