---
import Layout from '../layouts/Layout.astro';
import { recommendationData, wizardQuestions } from '../data/wizard';

const wizardRuntimeData = {
  questions: wizardQuestions,
  recommendations: recommendationData
};
---

<Layout
  title="Aquarium Wizard • Personalized Tank Recommendations"
  description="Answer five quick questions to get a personalized aquarium setup recommendation based on tank size, fish style, maintenance level, and budget."
>
  <main class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold text-primary mb-2">Aquarium Wizard</h1>
    <p class="text-xl text-accent-2 mb-10">Answer 5 quick questions and get your personalized recommendation</p>

    <div id="wizard" class="bg-white dark:bg-slate-900 rounded-3xl shadow-2xl p-8">
      {wizardQuestions.map((question, index) => (
        <div id={`step-${question.step}`} class={`step${index === 0 ? '' : ' hidden'}`}>
          <h3 class="text-3xl font-semibold text-accent-1 mb-6">{question.title}</h3>
          <div class="space-y-4">
            {question.options.map((option) => (
              <label class="flex items-center gap-3 text-lg cursor-pointer">
                <input type="radio" name={question.fieldName} value={option.value} class="accent-primary" /> {option.label}
              </label>
            ))}
          </div>
        </div>
      ))}

      <!-- Results -->
      <div id="results" class="hidden">
        <h3 class="text-4xl font-bold text-primary mb-6">Your Perfect Setup Recommendation</h3>
        <div id="recommendation" class="prose dark:prose-invert text-lg"></div>
        <div class="mt-8 flex gap-4">
          <a href="/shop" class="bg-primary text-white px-8 py-4 rounded-2xl font-medium hover:bg-accent-1">Shop My 3D-Printed Accessories</a>
          <a href="/guides" class="border-2 border-primary text-primary px-8 py-4 rounded-2xl font-medium hover:bg-accent-1 hover:text-white">Read Matching Guides</a>
        </div>
      </div>

      <!-- Navigation Buttons -->
      <div class="flex justify-between mt-10">
        <button id="prev-btn" class="px-8 py-3 border-2 border-primary text-primary rounded-2xl font-medium hover:bg-primary hover:text-white hidden">← Previous</button>
        <button id="next-btn" class="px-8 py-3 bg-primary text-white rounded-2xl font-medium hover:bg-accent-1">Next →</button>
      </div>
      <p id="wizard-error" class="mt-4 text-sm font-medium text-red-600 dark:text-red-400 hidden" aria-live="polite"></p>
    </div>
  </main>

  <script type="application/json" id="wizard-config">{JSON.stringify(wizardRuntimeData)}</script>
  <script>
    const wizardConfigEl = document.getElementById('wizard-config');
    const wizardConfig = JSON.parse(wizardConfigEl.textContent);
    let currentStep = 1;
    const totalSteps = wizardConfig.questions.length;
    const steps = document.querySelectorAll('.step');
    const nextBtn = document.getElementById('next-btn');
    const prevBtn = document.getElementById('prev-btn');
    const results = document.getElementById('results');
    const recommendation = document.getElementById('recommendation');
    const errorMessage = document.getElementById('wizard-error');
    const stepFields = Object.fromEntries(
      wizardConfig.questions.map((question) => [question.step, question.fieldName])
    );

    function showStep(n) {
      steps.forEach(s => s.classList.add('hidden'));
      document.getElementById(`step-${n}`).classList.remove('hidden');
      prevBtn.classList.toggle('hidden', n === 1);
      nextBtn.textContent = n === totalSteps ? 'Get My Recommendation' : 'Next →';
      clearError();
    }

    function showError(message) {
      errorMessage.textContent = message;
      errorMessage.classList.remove('hidden');
    }

    function clearError() {
      errorMessage.textContent = '';
      errorMessage.classList.add('hidden');
    }

    function hasAnswerForStep(stepNumber) {
      const fieldName = stepFields[stepNumber];
      return Boolean(document.querySelector(`input[name="${fieldName}"]:checked`));
    }

    function getAnswers() {
      return wizardConfig.questions.reduce((answers, question) => {
        const selectedValue = document.querySelector(`input[name="${question.fieldName}"]:checked`)?.value || '';
        answers[question.key] = selectedValue;
        return answers;
      }, {});
    }

    function generateRecommendation(answers) {
      if (!answers.tank || !answers.water || !answers.fish || !answers.maint || !answers.budget) {
        return '';
      }

      const tankProfile = wizardConfig.recommendations.tank[answers.tank];
      const waterProfile = wizardConfig.recommendations.water[answers.water];
      const fishProfile = wizardConfig.recommendations.fish[answers.fish];
      const maintenanceProfile = wizardConfig.recommendations.maint[answers.maint];
      const budgetProfile = wizardConfig.recommendations.budget[answers.budget];

      if (!tankProfile || !waterProfile || !fishProfile || !maintenanceProfile || !budgetProfile) {
        return '';
      }

      return `
        <p class="text-2xl mb-4">Based on your choices, we recommend a <strong>${tankProfile.headline} ${waterProfile.label} aquarium</strong>.</p>
        <p>This setup is ${tankProfile.environment} and follows ${waterProfile.experience}.</p>
        <p>Your stocking direction is a <strong>${fishProfile.label}</strong> with species such as ${fishProfile.stocking}.</p>
        <p>For equipment, start with ${tankProfile.equipment.join(', ')} and pair it with a ${maintenanceProfile.filter}.</p>
        <p>Your maintenance target is a <strong>${maintenanceProfile.label}</strong>: ${maintenanceProfile.routine}.</p>
        <p>Accessory plan: begin with a <strong>${budgetProfile.accessorySet}</strong> focused on ${budgetProfile.accessoryFocus.join(', ')}.</p>
        <p class="mt-6 text-accent-2">Estimated startup range: ${budgetProfile.startupCost}.</p>
        <ul>
          <li>${tankProfile.note}</li>
          <li>${waterProfile.equipmentNote}</li>
          <li>${fishProfile.temperament}</li>
          <li>${maintenanceProfile.note}</li>
        </ul>
        <p>Next reading: <a href="${fishProfile.guidePath}">browse matching aquarium guides</a>.</p>
      `;
    }

    nextBtn.addEventListener('click', () => {
      if (!hasAnswerForStep(currentStep)) {
        showError('Select an answer before continuing.');
        return;
      }

      if (currentStep < totalSteps) {
        currentStep++;
        showStep(currentStep);
      } else {
        const answers = getAnswers();
        const html = generateRecommendation(answers);

        if (!html) {
          showError('Complete every step before generating your recommendation.');
          return;
        }

        recommendation.innerHTML = html;
        document.getElementById('wizard').querySelectorAll('.step').forEach(s => s.classList.add('hidden'));
        results.classList.remove('hidden');
        nextBtn.classList.add('hidden');
        prevBtn.classList.add('hidden');
        clearError();
      }
    });

    prevBtn.addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        showStep(currentStep);
      }
    });

    Object.values(stepFields).forEach((fieldName) => {
      document.querySelectorAll(`input[name="${fieldName}"]`).forEach((input) => {
        input.addEventListener('change', clearError);
      });
    });

    // Start at step 1
    showStep(1);
  </script>
</Layout>
