---
import Layout from '../layouts/Layout.astro';
import { wizardQuestions } from '../data/wizard';
---

<Layout
  title="Fin Sanctuary Aquarium Wizard • Personalized Tank Recommendations"
  description="Answer a guided set of questions to get a personalized aquarium setup recommendation based on experience, environment, tank size, fish style, plants, maintenance, and budget."
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.1),rgba(243,239,238,0.55))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.15),rgba(2,6,23,0.96))]">
      <div class="mx-auto flex max-w-6xl justify-center px-6 py-10 md:py-12">
        <div class="w-full max-w-3xl rounded-[2rem] border border-primary/10 bg-white p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] dark:border-white/8 dark:bg-slate-900 sm:p-8">
          <div class="flex flex-col items-center gap-6 py-6 text-center sm:py-8">
            <img
              src="/images/home/aquarium-wizard-square.png"
              alt="Aquarium Wizard illustrated square banner"
              class="w-full max-w-2xl rounded-[1.5rem] shadow-[0_18px_55px_-35px_rgba(1,133,174,0.45)]"
              loading="eager"
            />
            <div>
              <h1 class="text-4xl font-bold leading-tight text-primary">
                Aquarium Wizard
              </h1>
              <p class="mt-2 text-lg text-primary/80 dark:text-accent-3">
                Personalized Aquarium Planning
              </p>
            </div>
            <p class="max-w-md text-base leading-relaxed text-slate-600 dark:text-slate-300">
              Answer a few simple questions about your conditions and goals — we'll recommend the perfect plans for your aquarium to grow and thrive.
            </p>
            <a href="#wizard" class="mt-1 inline-flex rounded-2xl bg-primary px-10 py-3 text-lg font-semibold text-white shadow-md transition-colors duration-200 hover:bg-accent-1">
              Get Started →
            </a>
            <p class="text-xs text-slate-400 dark:text-slate-500">
              {wizardQuestions.length} quick questions · no account required
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_19rem]">
        <div id="wizard" class="rounded-[2rem] border border-primary/10 bg-white p-7 shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] dark:border-white/8 dark:bg-slate-900 md:p-9">
          <div class="mb-8 flex flex-wrap items-center justify-between gap-3">
            <div>
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Guided Setup Flow</div>
              <h2 class="mt-2 font-semibold tracking-tight text-primary">Personalized recommendation builder</h2>
            </div>
            <div class="rounded-full border border-primary/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary/80 dark:border-primary/20">
              {wizardQuestions.length} questions
            </div>
          </div>

          {wizardQuestions.map((question, index) => (
            <div id={`step-${question.step}`} class={`step${index === 0 ? '' : ' hidden'}`}>
              <div class="mb-6 text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Step {question.step}</div>
              <h3 class="font-semibold tracking-tight text-primary">{question.title.replace(/^Step \d+:\s*/, '')}</h3>
              <div class="mt-6 space-y-4">
                {question.options.map((option) => (
                  <label class="flex cursor-pointer items-start gap-4 rounded-[1.5rem] border border-primary/10 bg-light-bg/40 px-5 py-4 transition-colors hover:border-primary/30 hover:bg-white dark:border-white/8 dark:bg-slate-950/70 dark:hover:bg-slate-950">
                    <input type="radio" name={question.fieldName} value={option.value} class="mt-1 accent-primary" />
                    <span class="text-slate-700 dark:text-slate-200">{option.label}</span>
                  </label>
                ))}
              </div>
            </div>
          ))}

          <div id="results" class="hidden">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Recommendation Ready</div>
            <h3 class="mt-2 font-bold tracking-tight text-primary">Your aquarium direction</h3>
            <div id="recommendation" class="wizard-result mt-8"></div>
          </div>

          <div class="mt-8 flex flex-wrap justify-between gap-4">
            <button id="prev-btn" class="hidden rounded-full border border-primary/20 px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" type="button">Previous</button>
            <button id="next-btn" class="rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" type="button">Next</button>
          </div>
          <p id="wizard-error" class="mt-4 text-sm font-medium text-red-600 dark:text-red-400 hidden" aria-live="polite"></p>
        </div>

        <aside class="space-y-6 xl:sticky xl:top-28 xl:self-start">
          <section class="rounded-[2rem] border border-primary/10 bg-white p-6 dark:border-white/8 dark:bg-slate-900">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">How to use it</div>
            <ul class="mt-4 space-y-3 text-slate-700 dark:text-slate-300">
              <li>Answer based on the tank you are actually likely to maintain.</li>
              <li>Do not choose saltwater unless you genuinely want the extra cost and work.</li>
              <li>Treat the output as a planning direction, then read the matched guides before buying equipment.</li>
            </ul>
          </section>
          <section class="rounded-[2rem] border border-primary/10 bg-white p-6 dark:border-white/8 dark:bg-slate-900">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Built for</div>
            <p class="mt-4 text-slate-700 dark:text-slate-300">Home and small-office aquarium owners who want a calmer first decision instead of random forum advice and impulse shopping.</p>
          </section>
        </aside>
      </div>
    </section>
  </main>

  <script>
    import { buildWizardRecommendation, isCompleteWizardAnswers, wizardQuestions } from '../data/wizard';

    let currentStep = 1;
    const totalSteps = wizardQuestions.length;
    const steps = document.querySelectorAll('.step');
    const nextBtn = document.getElementById('next-btn');
    const prevBtn = document.getElementById('prev-btn');
    const results = document.getElementById('results');
    const recommendation = document.getElementById('recommendation');
    const errorMessage = document.getElementById('wizard-error');
    const stepFields = Object.fromEntries(wizardQuestions.map((question) => [question.step, question.fieldName]));

    function showStep(n) {
      steps.forEach((step) => step.classList.add('hidden'));
      document.getElementById(`step-${n}`).classList.remove('hidden');
      prevBtn.classList.toggle('hidden', n === 1);
      nextBtn.textContent = n === totalSteps ? 'Get My Recommendation' : 'Next';
      clearError();
    }

    function showError(message) {
      errorMessage.textContent = message;
      errorMessage.classList.remove('hidden');
    }

    function clearError() {
      errorMessage.textContent = '';
      errorMessage.classList.add('hidden');
    }

    function hasAnswerForStep(stepNumber) {
      const fieldName = stepFields[stepNumber];
      return Boolean(document.querySelector(`input[name="${fieldName}"]:checked`));
    }

    function getAnswers() {
      return wizardQuestions.reduce((answers, question) => {
        const selectedValue = document.querySelector(`input[name="${question.fieldName}"]:checked`)?.value || '';
        answers[question.key] = selectedValue;
        return answers;
      }, {});
    }

    function renderList(items) {
      return `<ul>${items.join('')}</ul>`;
    }

    function renderRecommendation(result) {
      if (!result) {
        return '';
      }

      return `
        <div class="space-y-8">
          <section>
            <p class="text-slate-700 dark:text-slate-200">Based on your choices, we recommend a <strong class="text-primary">${result.headline}</strong>.</p>
            <div class="mt-4 space-y-3 text-slate-700 dark:text-slate-300">
              <p>${result.setupSummary}</p>
              <p>${result.stockingSummary}</p>
              <p>${result.maintenanceSummary}</p>
            </div>
          </section>

          <section class="rounded-[1.6rem] border border-primary/10 bg-light-bg/35 p-6 dark:border-white/8 dark:bg-slate-950/60">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Sample Stocking Plan</div>
            <p class="mt-3 font-semibold text-primary">${result.stockingPlan.title}</p>
            <p class="mt-2 text-slate-700 dark:text-slate-300">${result.stockingPlan.summary}</p>
            ${renderList(result.stockingPlan.entries.map((entry) => `<li><strong>${entry.species}</strong> (${entry.count}) - ${entry.role}</li>`))}
          </section>

          <section>
            <h4>Fish We Recommend</h4>
            ${renderList(result.fishRecommendations.map((fish) => `<li><strong>${fish.name}</strong> (${fish.stockingCount}) - ${fish.reason} Compatibility: ${fish.compatibility}</li>`))}
          </section>

          <section>
            <h4>Avoid These Fish</h4>
            ${renderList(result.avoidFish.map((fish) => `<li><strong>${fish.name}</strong> - ${fish.reason}</li>`))}
          </section>

          <section>
            <h4>Suggested Equipment Bundle</h4>
            <p><strong>${result.equipmentBundle.name}</strong>: ${result.equipmentBundle.summary}</p>
            ${renderList(result.equipmentBundle.items.map((item) => `<li>${item}</li>`))}
          </section>

          <section>
            <h4>Recommended Accessories</h4>
            ${renderList(result.accessoryProducts.map((product) => `<li><a href="${product.href}">${product.name}</a> (${product.price}) - ${product.summary}</li>`))}
          </section>

          <section>
            <h4>Guides to Read Next</h4>
            ${renderList(result.matchedGuides.map((guide) => `<li><a href="/guides/${guide.slug}">${guide.title}</a> - ${guide.reason}</li>`))}
          </section>

          <section class="rounded-[1.6rem] border border-dashed border-primary/20 p-6">
            <p class="text-slate-700 dark:text-slate-300">Estimated startup range: <strong class="text-primary">${result.startupRange}</strong>.</p>
            ${renderList(result.notes.map((note) => `<li>${note}</li>`))}
          </section>

          <div class="flex flex-wrap gap-4">
            <a href="/shop" class="inline-flex rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1">Shop Matching Accessories</a>
            <a href="/guides" class="inline-flex rounded-full border border-primary/20 px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">Browse All Guides</a>
          </div>
        </div>
      `;
    }

    nextBtn.addEventListener('click', () => {
      if (!hasAnswerForStep(currentStep)) {
        showError('Select an answer before continuing.');
        return;
      }

      if (currentStep < totalSteps) {
        currentStep++;
        showStep(currentStep);
      } else {
        const answers = getAnswers();

        if (!isCompleteWizardAnswers(answers)) {
          showError('Complete every step before generating your recommendation.');
          return;
        }

        const html = renderRecommendation(buildWizardRecommendation(answers));

        if (!html) {
          showError('Complete every step before generating your recommendation.');
          return;
        }

        recommendation.innerHTML = html;
        document.getElementById('wizard').querySelectorAll('.step').forEach((step) => step.classList.add('hidden'));
        results.classList.remove('hidden');
        nextBtn.classList.add('hidden');
        prevBtn.classList.add('hidden');
        clearError();
      }
    });

    prevBtn.addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        showStep(currentStep);
      }
    });

    Object.values(stepFields).forEach((fieldName) => {
      document.querySelectorAll(`input[name="${fieldName}"]`).forEach((input) => {
        input.addEventListener('change', clearError);
      });
    });

    showStep(1);
  </script>
</Layout>

<style>
  .wizard-result :global(h4) {
    margin-bottom: 0.8rem;
    color: var(--color-primary);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .wizard-result :global(p),
  .wizard-result :global(li) {
    color: rgb(51 65 85);
    line-height: 1.9;
  }

  :global(.dark) .wizard-result :global(p),
  :global(.dark) .wizard-result :global(li) {
    color: rgb(226 232 240);
  }

  .wizard-result :global(ul) {
    margin-top: 0.9rem;
    padding-left: 1.3rem;
  }

  .wizard-result :global(li + li) {
    margin-top: 0.45rem;
  }

  .wizard-result :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }
</style>
