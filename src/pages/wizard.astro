---
import Layout from '../layouts/Layout.astro';
import { wizardQuestions } from '../data/wizard';
---

<Layout
  title="Aquarium Wizard • Personalized Tank Recommendations"
  description="Answer a guided set of questions to get a personalized aquarium setup recommendation based on experience, environment, tank size, fish style, plants, maintenance, and budget."
>
  <main class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold text-primary mb-2">Aquarium Wizard</h1>
    <p class="text-xl text-accent-2 mb-10">Answer 8 quick questions and get a more precise setup recommendation</p>

    <div id="wizard" class="bg-white dark:bg-slate-900 rounded-3xl shadow-2xl p-8">
      {wizardQuestions.map((question, index) => (
        <div id={`step-${question.step}`} class={`step${index === 0 ? '' : ' hidden'}`}>
          <h3 class="text-3xl font-semibold text-accent-1 mb-6">{question.title}</h3>
          <div class="space-y-4">
            {question.options.map((option) => (
              <label class="flex items-center gap-3 text-lg cursor-pointer">
                <input type="radio" name={question.fieldName} value={option.value} class="accent-primary" /> {option.label}
              </label>
            ))}
          </div>
        </div>
      ))}

      <div id="results" class="hidden">
        <h3 class="text-4xl font-bold text-primary mb-6">Your Perfect Setup Recommendation</h3>
        <div id="recommendation" class="prose dark:prose-invert text-lg"></div>
      </div>

      <div class="flex justify-between mt-10">
        <button id="prev-btn" class="px-8 py-3 border-2 border-primary text-primary rounded-2xl font-medium hover:bg-primary hover:text-white hidden">← Previous</button>
        <button id="next-btn" class="px-8 py-3 bg-primary text-white rounded-2xl font-medium hover:bg-accent-1">Next →</button>
      </div>
      <p id="wizard-error" class="mt-4 text-sm font-medium text-red-600 dark:text-red-400 hidden" aria-live="polite"></p>
    </div>
  </main>

  <script>
    import { buildWizardRecommendation, isCompleteWizardAnswers, wizardQuestions } from '../data/wizard';

    let currentStep = 1;
    const totalSteps = wizardQuestions.length;
    const steps = document.querySelectorAll('.step');
    const nextBtn = document.getElementById('next-btn');
    const prevBtn = document.getElementById('prev-btn');
    const results = document.getElementById('results');
    const recommendation = document.getElementById('recommendation');
    const errorMessage = document.getElementById('wizard-error');
    const stepFields = Object.fromEntries(
      wizardQuestions.map((question) => [question.step, question.fieldName])
    );

    function showStep(n) {
      steps.forEach((step) => step.classList.add('hidden'));
      document.getElementById(`step-${n}`).classList.remove('hidden');
      prevBtn.classList.toggle('hidden', n === 1);
      nextBtn.textContent = n === totalSteps ? 'Get My Recommendation' : 'Next →';
      clearError();
    }

    function showError(message) {
      errorMessage.textContent = message;
      errorMessage.classList.remove('hidden');
    }

    function clearError() {
      errorMessage.textContent = '';
      errorMessage.classList.add('hidden');
    }

    function hasAnswerForStep(stepNumber) {
      const fieldName = stepFields[stepNumber];
      return Boolean(document.querySelector(`input[name="${fieldName}"]:checked`));
    }

    function getAnswers() {
      return wizardQuestions.reduce((answers, question) => {
        const selectedValue = document.querySelector(`input[name="${question.fieldName}"]:checked`)?.value || '';
        answers[question.key] = selectedValue;
        return answers;
      }, {});
    }

    function renderRecommendation(result) {
      if (!result) {
        return '';
      }

      return `
        <p class="text-2xl mb-4">Based on your choices, we recommend a <strong>${result.headline}</strong>.</p>
        <p>${result.setupSummary}</p>
        <p>${result.stockingSummary}</p>
        <p>${result.maintenanceSummary}</p>
        <h4 class="mt-8 text-primary">Suggested Equipment Bundle</h4>
        <p><strong>${result.equipmentBundle.name}</strong>: ${result.equipmentBundle.summary}</p>
        <ul>
          ${result.equipmentBundle.items.map((item) => `<li>${item}</li>`).join('')}
        </ul>
        <h4 class="mt-8 text-primary">Recommended Accessories</h4>
        <ul>
          ${result.accessoryProducts.map((product) => `<li><a href="${product.href}">${product.name}</a> (${product.price}) — ${product.summary}</li>`).join('')}
        </ul>
        <h4 class="mt-8 text-primary">Guides to Read Next</h4>
        <ul>
          ${result.matchedGuides.map((guide) => `<li><a href="/guides/${guide.slug}">${guide.title}</a> — ${guide.reason}</li>`).join('')}
        </ul>
        <p class="mt-6 text-accent-2">Estimated startup range: ${result.startupRange}.</p>
        <ul>
          ${result.notes.map((note) => `<li>${note}</li>`).join('')}
        </ul>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/shop" class="inline-block rounded-2xl bg-primary px-8 py-4 font-medium text-white hover:bg-accent-1">Shop Matching Accessories</a>
          <a href="/guides" class="inline-block rounded-2xl border-2 border-primary px-8 py-4 font-medium text-primary hover:bg-accent-1 hover:text-white">Browse All Guides</a>
        </div>
      `;
    }

    nextBtn.addEventListener('click', () => {
      if (!hasAnswerForStep(currentStep)) {
        showError('Select an answer before continuing.');
        return;
      }

      if (currentStep < totalSteps) {
        currentStep++;
        showStep(currentStep);
      } else {
        const answers = getAnswers();

        if (!isCompleteWizardAnswers(answers)) {
          showError('Complete every step before generating your recommendation.');
          return;
        }

        const html = renderRecommendation(buildWizardRecommendation(answers));

        if (!html) {
          showError('Complete every step before generating your recommendation.');
          return;
        }

        recommendation.innerHTML = html;
        document.getElementById('wizard').querySelectorAll('.step').forEach((step) => step.classList.add('hidden'));
        results.classList.remove('hidden');
        nextBtn.classList.add('hidden');
        prevBtn.classList.add('hidden');
        clearError();
      }
    });

    prevBtn.addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        showStep(currentStep);
      }
    });

    Object.values(stepFields).forEach((fieldName) => {
      document.querySelectorAll(`input[name="${fieldName}"]`).forEach((input) => {
        input.addEventListener('change', clearError);
      });
    });

    showStep(1);
  </script>
</Layout>
