---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Aquarium Guides • Setup, Cycling, and Tank Care"
  description="Browse aquarium guides covering beginner tank setup, maintenance, cycling, equipment, and common home aquarium problems."
>
  <main class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold text-primary mb-4">Knowledge Guides</h1>
    <p class="text-xl text-accent-2 mb-10">Everything you need to know about home aquariums — updated 2026</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Your first guide card -->
      <a href="/guides/beginner-tank-setup" 
         class="bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-xl hover:shadow-2xl transition-all group">
        <div class="text-xs uppercase tracking-widest text-accent-1 mb-2">Setup & Maintenance</div>
        <h3 class="text-2xl font-semibold text-primary group-hover:text-accent-1 transition-colors">Complete Beginner Tank Setup Guide 2026</h3>
        <p class="text-warm-neutral mt-4 line-clamp-3">Step-by-step guide to cycling your first aquarium and avoiding the #1 beginner mistake</p>
        <div class="mt-6 text-sm text-accent-2">Read →</div>
      </a>
    </div>
  </main>
</Layout>
