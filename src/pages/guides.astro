---
import AdSenseBlock from '../components/AdSenseBlock.astro';
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const upcomingGuides = [
  {
    title: 'Weekly Aquarium Maintenance Routine for Busy Owners',
    description: '15-minute checklist covering cleaning, feeding, and visual health checks designed for home and desk aquariums.',
    category: 'Water Quality & Maintenance'
  },
  {
    title: 'Best Beginner Fish for Small Home and Office Tanks',
    description: 'Top 10 easy species with stocking guidelines and compatibility charts for smaller freshwater setups.',
    category: 'Fish & Invertebrate Care'
  },
  {
    title: 'Betta Fish Care: Solo Tanks, Feeding & Enrichment',
    description: 'Complete guide to keeping bettas happy and healthy in 5–10 gallon setups ideal for desks and nightstands.',
    category: 'Fish & Invertebrate Care'
  },
  {
    title: 'Community Tank Compatibility Guide',
    description: 'Safe species mixes that prevent aggression and stress in shared 10–30 gallon home aquariums.',
    category: 'Fish & Invertebrate Care'
  },
  {
    title: 'Safe Acclimation Techniques for New Fish and Shrimp',
    description: 'Step-by-step drip and float methods to eliminate transport shock and prevent early losses.',
    category: 'Fish & Invertebrate Care'
  },
  {
    title: 'Invertebrate Care: Snails, Shrimp & Crayfish in Small Tanks',
    description: 'Which cleanup crew members thrive in nano and office aquariums without destroying plants.',
    category: 'Fish & Invertebrate Care'
  },
  {
    title: 'Live Plants vs Artificial Plants: Which Is Best for You?',
    description: 'Pros, cons, and hybrid setups that look natural with minimal maintenance in busy households.',
    category: 'Plants & Aquascaping'
  },
  {
    title: 'Setting Up a Low-Maintenance Planted Aquarium',
    description: 'Substrate, lighting, easy plant species, and fertilizer tips for lush tanks that fit on any office shelf.',
    category: 'Plants & Aquascaping'
  },
  {
    title: 'Aquascaping Basics: Creating Stunning Underwater Landscapes',
    description: 'Design rules using rocks, driftwood, and plants to turn any small tank into a living centerpiece.',
    category: 'Plants & Aquascaping'
  },
  {
    title: 'Identifying and Treating Common Fish Diseases',
    description: 'Spot ich, fin rot, or swim bladder issues early and use safe, over-the-counter treatments.',
    category: 'Health & Troubleshooting'
  },
  {
    title: 'Overfeeding vs Underfeeding: Nutrition Guidelines',
    description: 'Feeding schedules and food types that keep fish vibrant without polluting small-volume water.',
    category: 'Health & Troubleshooting'
  },
  {
    title: 'Emergency Aquarium Troubleshooting Guide',
    description: 'Quick fixes for cloudy water, jumping fish, power outages, or sudden temperature drops.',
    category: 'Health & Troubleshooting'
  },
  {
    title: 'Nano Aquarium Care for Tiny Spaces',
    description: 'Special tips for tanks under 10 gallons, perfect for dorms, cubicles, and modern apartments.',
    category: 'Specialty & Advanced Care'
  },
  {
    title: 'Goldfish Care Myths Busted',
    description: 'Why most small bowls fail and how to keep fancy goldfish healthy in proper home setups.',
    category: 'Specialty & Advanced Care'
  },
  {
    title: 'Breeding Easy Aquarium Fish at Home',
    description: 'Beginner-friendly species and simple spawning setups for livebearers and invertebrates.',
    category: 'Specialty & Advanced Care'
  },
  {
    title: 'Seasonal Aquarium Care: Summer Heat & Winter Tips',
    description: 'Protect your tank from temperature swings and evaporation common in homes and offices.',
    category: 'Automation, Sustainability & Upgrades'
  },
  {
    title: 'Low-Tech vs High-Tech Planted Tanks',
    description: 'Compare CO2 systems and advanced lighting with simple methods that still deliver beautiful results.',
    category: 'Specialty & Advanced Care'
  },
  {
    title: 'Aquarium Automation for Busy Owners',
    description: 'Smart timers, auto-feeders, and dosing pumps that make small-tank care almost hands-free.',
    category: 'Automation, Sustainability & Upgrades'
  },
  {
    title: 'Eco-Friendly Aquarium Practices',
    description: 'Sustainable choices in equipment, decor, and fish sourcing that reduce your environmental footprint.',
    category: 'Automation, Sustainability & Upgrades'
  },
  {
    title: 'Upgrading Your Aquarium: When and How to Scale Up',
    description: 'Signs your tank needs more space plus seamless move strategies for growing home or office collections.',
    category: 'Automation, Sustainability & Upgrades'
  }
];

const topicSections = [
  {
    id: 'setup-planning',
    label: 'Setup & Planning',
    categories: ['Aquarium Setup & Planning', 'Planning', 'Setup & Maintenance']
  },
  {
    id: 'equipment-technology',
    label: 'Equipment & Technology',
    categories: ['Equipment & Technology', 'Equipment']
  },
  {
    id: 'water-quality-maintenance',
    label: 'Water Quality & Maintenance',
    categories: ['Water Quality & Maintenance']
  },
  {
    id: 'fish-invertebrate-care',
    label: 'Fish & Invertebrate Care',
    categories: ['Fish & Invertebrate Care', 'Freshwater Fish']
  },
  {
    id: 'plants-aquascaping',
    label: 'Plants & Aquascaping',
    categories: ['Plants & Aquascaping']
  },
  {
    id: 'health-troubleshooting',
    label: 'Health & Troubleshooting',
    categories: ['Health & Troubleshooting']
  },
  {
    id: 'specialty-advanced-care',
    label: 'Specialty & Advanced Care',
    categories: ['Specialty & Advanced Care']
  },
  {
    id: 'automation-sustainability-upgrades',
    label: 'Automation, Sustainability & Upgrades',
    categories: ['Automation, Sustainability & Upgrades']
  }
];

const sections = topicSections.map((section) => ({
  ...section,
  liveGuides: guides.filter((guide) => section.categories.includes(guide.data.category)),
  plannedGuides: upcomingGuides.filter((guide) => section.categories.includes(guide.category))
}));

const guidesHubAdSlot = import.meta.env.PUBLIC_ADSENSE_GUIDES_HUB_SLOT;
---

<Layout
  title="Aquarium Guides • Setup, Cycling, and Tank Care"
  description="Browse aquarium guides covering beginner tank setup, maintenance, cycling, equipment, and common home aquarium problems."
>
  <main class="max-w-6xl mx-auto px-6 py-10">
    <section class="mb-10 flex justify-center">
      <div class="w-full max-w-[42rem] rounded-[2rem] border border-primary/10 bg-white p-5 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] dark:border-white/8 dark:bg-slate-900 sm:p-7">
        <div class="flex flex-col items-center gap-5 py-4 text-center sm:py-6">
          <img
            src="/images/home/finpedia-square.png"
            alt="Finpedia illustrated square banner"
            class="w-full max-w-[24rem] rounded-[1.5rem] shadow-[0_18px_55px_-35px_rgba(1,133,174,0.45)]"
            loading="eager"
          />
          <div>
            <h1 class="text-4xl font-bold leading-tight text-primary">
              Finpedia
            </h1>
            <p class="mt-2 text-lg text-primary/80 dark:text-accent-3">
              Aquarium Knowledge Library
            </p>
          </div>
          <p class="max-w-md text-base leading-relaxed text-slate-600 dark:text-slate-300">
            Start with beginner setup, compare freshwater and saltwater paths, then branch into fish care, filters, maintenance, and equipment guides built for home and small-office aquariums.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            {sections.map((section) => (
              <a
                href={`#${section.id}`}
                class="rounded-full bg-light-bg px-4 py-2 text-sm font-medium text-primary shadow transition-colors hover:bg-primary hover:text-white dark:bg-slate-950"
              >
                {section.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <AdSenseBlock className="mb-10 shadow-[0_24px_80px_-60px_rgba(1,133,174,0.35)]" label="Advertisement" slot={guidesHubAdSlot} />

    <div class="space-y-12">
      {sections.map((section) => (
        <section id={section.id} class="scroll-mt-28">
          <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div>
              <div class="text-xs uppercase tracking-widest text-accent-1">{section.label}</div>
              <h2 class="mt-3 font-semibold text-primary">{section.label}</h2>
            </div>
            <p class="max-w-2xl text-slate-600 dark:text-slate-300">
              {section.liveGuides.length > 0
                ? 'Published guides and planned topics grouped by the main subject area.'
                : 'Planned topics grouped here now and ready for full guide buildouts later.'}
            </p>
          </div>

          {(section.liveGuides.length > 0 || section.plannedGuides.length > 0) && (
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
              {section.liveGuides.map((guide) => (
                <a href={`/guides/${guide.id}`} class="group rounded-[1.75rem] bg-white p-8 shadow-xl transition-all hover:shadow-2xl dark:bg-slate-900">
                  <div class="text-xs uppercase tracking-widest text-accent-1 mb-2">{guide.data.category}</div>
                  <h3 class="font-semibold text-primary transition-colors group-hover:text-accent-1">{guide.data.title}</h3>
                  <p class="mt-4 line-clamp-3 text-warm-neutral">{guide.data.description}</p>
                  <div class="mt-4 text-xs text-accent-2">{guide.data.audience === 'beginner' ? 'Beginner Friendly' : 'For Growing Hobbyists'}</div>
                  <div class="mt-6 text-sm text-accent-2">Read →</div>
                </a>
              ))}

              {section.plannedGuides.map((guide) => (
                <article class="rounded-[1.75rem] border border-dashed border-primary/20 bg-white/70 p-7 shadow-[0_24px_80px_-60px_rgba(1,133,174,0.35)] dark:border-primary/20 dark:bg-slate-900/75">
                  <div class="flex items-center justify-between gap-4">
                    <div class="text-[0.68rem] uppercase tracking-[0.24em] text-accent-1">{guide.category}</div>
                    <span class="rounded-full border border-primary/15 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-primary/80 dark:border-primary/25">
                      Placeholder
                    </span>
                  </div>
                  <h3 class="mt-4 font-semibold text-primary">{guide.title}</h3>
                  <p class="mt-3 text-slate-600 dark:text-slate-300">{guide.description}</p>
                </article>
              ))}
            </div>
          )}
        </section>
      ))}
    </div>
  </main>
</Layout>
