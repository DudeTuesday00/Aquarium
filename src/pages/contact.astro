---
import NewsletterSignupCard from '../components/NewsletterSignupCard.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Fin Sanctuary"
  description="Get in touch about aquarium questions, custom 3D-printed accessories, or newsletter updates from Fin Sanctuary."
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.08),rgba(243,239,238,0.55))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.14),rgba(2,6,23,0.95))]">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:py-12 xl:grid-cols-[minmax(0,1fr)_22rem] xl:items-end">
        <div>
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Contact + Email Updates</div>
          <h1 class="mt-5 font-bold tracking-tight text-primary">Get in touch about tanks, accessories, or custom prints.</h1>
          <p class="mt-6 max-w-3xl text-slate-700 dark:text-slate-200">
            Use the form for aquarium questions, custom 3D-printed accessory requests, product fit questions, or general site feedback. You can also reach the site by email if you want the fastest route to the right inbox.
          </p>
        </div>
        <div class="rounded-[2rem] border border-primary/10 bg-white/80 p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] backdrop-blur dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Response Time</div>
          <p class="mt-4 text-slate-700 dark:text-slate-300">Replies are typically sent within 24 hours. Use <a href="mailto:drodge00@finsanctuary.com" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4" data-track-click="email_click" data-track-location="contact-response-time" data-track-label="drodge00@finsanctuary.com" data-track-category="contact" data-track-destination="mailto:drodge00@finsanctuary.com">drodge00@finsanctuary.com</a> for direct personal contact, or use the role-based addresses below for general inquiries, support, and newsletter topics.</p>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
        <section class="rounded-[2rem] border border-primary/10 bg-white p-7 shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] dark:border-white/8 dark:bg-slate-900 md:p-8">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Contact Form</div>
          <form action="https://formspree.io/f/xpqynalz" method="POST" class="mt-6 space-y-5" data-track-submit="contact_form_submit" data-track-location="contact-page" data-track-label="Contact Form" data-track-category="contact">
            <div>
              <label class="mb-2 block text-sm font-semibold text-primary">Your Name</label>
              <input type="text" name="name" required class="w-full rounded-[1.25rem] border border-primary/15 bg-light-bg/35 px-5 py-4 text-slate-900 outline-none transition-colors focus:border-primary dark:border-white/10 dark:bg-slate-950 dark:text-white" />
            </div>
            <div>
              <label class="mb-2 block text-sm font-semibold text-primary">Email Address</label>
              <input type="email" name="email" required class="w-full rounded-[1.25rem] border border-primary/15 bg-light-bg/35 px-5 py-4 text-slate-900 outline-none transition-colors focus:border-primary dark:border-white/10 dark:bg-slate-950 dark:text-white" />
            </div>
            <div>
              <label class="mb-2 block text-sm font-semibold text-primary">Message</label>
              <textarea name="message" rows="7" required class="w-full rounded-[1.25rem] border border-primary/15 bg-light-bg/35 px-5 py-4 text-slate-900 outline-none transition-colors focus:border-primary dark:border-white/10 dark:bg-slate-950 dark:text-white"></textarea>
            </div>
            <button type="submit" class="inline-flex rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1">
              Send Message
            </button>
          </form>
        </section>

        <aside class="space-y-6">
          <section class="rounded-[2rem] border border-primary/10 bg-white p-7 dark:border-white/8 dark:bg-slate-900 md:p-8">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Email Directory</div>
            <div class="mt-5 space-y-5 text-slate-700 dark:text-slate-300">
              <div>
                <h2 class="font-semibold tracking-tight text-primary">Direct Contact</h2>
                <p class="mt-2">For personal contact with Dave, email <a href="mailto:drodge00@finsanctuary.com" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4" data-track-click="email_click" data-track-location="contact-directory" data-track-label="drodge00@finsanctuary.com" data-track-category="contact" data-track-destination="mailto:drodge00@finsanctuary.com">drodge00@finsanctuary.com</a>.</p>
              </div>
              <div>
                <h2 class="font-semibold tracking-tight text-primary">General Info</h2>
                <p class="mt-2">For general site questions, business inquiries, and broad information requests, use <a href="mailto:info@finsanctuary.com" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4" data-track-click="email_click" data-track-location="contact-directory" data-track-label="info@finsanctuary.com" data-track-category="contact" data-track-destination="mailto:info@finsanctuary.com">info@finsanctuary.com</a>.</p>
              </div>
              <div>
                <h2 class="font-semibold tracking-tight text-primary">Support</h2>
                <p class="mt-2">For product help, order-related questions, print-fit questions, or troubleshooting, use <a href="mailto:support@finsanctuary.com" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4" data-track-click="email_click" data-track-location="contact-directory" data-track-label="support@finsanctuary.com" data-track-category="contact" data-track-destination="mailto:support@finsanctuary.com">support@finsanctuary.com</a>.</p>
              </div>
              <div>
                <h2 class="font-semibold tracking-tight text-primary">Newsletter</h2>
                <p class="mt-2">For newsletter-related updates and future list communications, use <a href="mailto:newsletter@finsanctuary.com" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4" data-track-click="email_click" data-track-location="contact-directory" data-track-label="newsletter@finsanctuary.com" data-track-category="newsletter" data-track-destination="mailto:newsletter@finsanctuary.com">newsletter@finsanctuary.com</a>.</p>
              </div>
            </div>
          </section>

          <NewsletterSignupCard
            interest="newsletter-contact-page"
            buttonLabel="Join the List"
            description="Use this signup for new guides, product drops, and practical aquarium updates. Newsletter-specific questions can still go to newsletter@finsanctuary.com."
            note="Emails can cover new guides, fish care tips, accessory launches, and seasonal maintenance reminders."
          />
        </aside>
      </div>

      <div class="mt-8 rounded-[1.5rem] border border-primary/10 bg-white/80 px-6 py-5 text-sm text-slate-600 dark:border-white/8 dark:bg-slate-900/80 dark:text-slate-300">
        Fin Sanctuary uses clear commercial disclosures. See the <a href="/advertising-disclosure" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4">Advertising Disclosure</a> and <a href="/affiliate-disclosure" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4">Affiliate Disclosure</a>.
      </div>
    </section>
  </main>
</Layout>
