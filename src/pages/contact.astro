---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Aquarium Wizard"
  description="Get in touch about aquarium questions, custom 3D-printed accessories, or newsletter updates from Aquarium Wizard."
>
  <main class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold text-primary mb-4">Get in Touch</h1>
    <p class="text-xl text-accent-2 mb-10">Questions about aquariums, custom 3D prints, or just say hello!</p>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div>
        <form action="https://formspree.io/f/xpqynalz" method="POST" class="space-y-6">
          <div>
            <label class="block text-sm font-medium mb-2">Your Name</label>
            <input type="text" name="name" required 
                   class="w-full px-6 py-4 rounded-2xl border border-primary/30 focus:border-primary bg-white dark:bg-slate-900">
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Email Address</label>
            <input type="email" name="email" required 
                   class="w-full px-6 py-4 rounded-2xl border border-primary/30 focus:border-primary bg-white dark:bg-slate-900">
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Message</label>
            <textarea name="message" rows="6" required 
                      class="w-full px-6 py-4 rounded-2xl border border-primary/30 focus:border-primary bg-white dark:bg-slate-900"></textarea>
          </div>
          <button type="submit"
                  class="w-full bg-primary text-white py-4 rounded-2xl font-medium hover:bg-accent-1 transition-colors">
            Send Message
          </button>
        </form>
        <p class="text-xs text-warm-neutral mt-4 text-center">We reply within 24 hours (usually much faster!)</p>
      </div>

      <!-- Newsletter Signup -->
      <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-xl">
        <h3 class="text-2xl font-semibold text-primary mb-4">Join the Newsletter</h3>
        <p class="text-warm-neutral mb-6">Monthly tips, new 3D prints, and exclusive deals for home aquarium fans.</p>
        
        <form action="https://formspree.io/f/xpqynalz" method="POST" class="space-y-4">
          <input type="email" name="email" placeholder="your@email.com" required
                 class="w-full px-6 py-4 rounded-2xl border border-primary/30 focus:border-primary bg-white dark:bg-slate-900">
          <button type="submit"
                  class="w-full bg-accent-1 text-white py-4 rounded-2xl font-medium hover:bg-primary transition-colors">
            Subscribe Free
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>
