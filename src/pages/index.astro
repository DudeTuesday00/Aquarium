---
import AdSenseBlock from '../components/AdSenseBlock.astro';
import NewsletterSignupCard from '../components/NewsletterSignupCard.astro';
import Layout from '../layouts/Layout.astro';

const homeInlineAdSlot = import.meta.env.PUBLIC_ADSENSE_HOME_INLINE_SLOT;
---

<Layout
  title="Fin Sanctuary • Home Tanks Made Easy"
  description="Plan a home aquarium with a guided wizard, long-form aquarium guides, and custom 3D-printed accessories for practical daily tank care."
  ogImage="/images/og/home.svg"
>
  <main>
    <section class="mx-auto max-w-6xl px-6 pt-10 pb-6 md:pt-12 md:pb-8">
      <div class="mx-auto max-w-3xl text-center">
        <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Start Here</div>
        <h1 class="mt-4 font-bold tracking-tight text-primary">Choose the right first step for your home aquarium.</h1>
        <p class="mt-5 text-slate-700 dark:text-slate-200">
          Fin Sanctuary helps USA-based home and small-office aquarium owners plan smarter before they buy, whether they need a guided recommendation or a deep educational guide.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-8 md:pb-10">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <div class="rounded-[2rem] border border-primary/10 bg-white px-7 py-8 shadow-[0_22px_80px_-55px_rgba(1,133,174,0.45)] dark:border-white/8 dark:bg-slate-900 md:px-8">
          <div class="flex justify-center">
            <img
              src="/images/home/aquarium-wizard.png"
              alt="Aquarium Wizard banner"
              class="w-full max-w-[26rem] rounded-[1.25rem]"
              loading="eager"
            />
          </div>
          <h2 class="mt-3 font-semibold tracking-tight text-primary">Start with the wizard when you need direction.</h2>
          <p class="mt-4 text-slate-700 dark:text-slate-300">
            The wizard is for people who know they want an aquarium but do not yet know the right tank size, fish type, maintenance load, or equipment path.
          </p>
          <ul class="mt-6 space-y-3 text-slate-700 dark:text-slate-300">
            <li>Tank size, water type, fish style, budget, maintenance, plants, and room placement all shape the recommendation.</li>
            <li>You get fish suggestions, stocking plans, equipment bundles, and matched reading instead of generic beginner fluff.</li>
            <li>The goal is to reduce mistakes before the first purchase.</li>
          </ul>
          <a href="/wizard" class="mt-7 inline-flex rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="cta_click" data-track-location="home-hero-wizard" data-track-label="Open the Wizard" data-track-category="navigation" data-track-destination="/wizard">Open the Wizard</a>
          <a href="/start-here" class="mt-4 inline-flex rounded-full border border-primary/20 px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="cta_click" data-track-location="home-hero-start-here" data-track-label="Need a simpler path?" data-track-category="navigation" data-track-destination="/start-here">Need a simpler path?</a>
        </div>

        <div class="rounded-[2rem] border border-primary/10 bg-white px-7 py-8 dark:border-white/8 dark:bg-slate-900 md:px-8">
          <div class="flex justify-center">
            <img
              src="/images/home/finpedia.png"
              alt="Finpedia banner"
              class="w-full max-w-[26rem] rounded-[1.25rem]"
              loading="eager"
            />
          </div>
          <h2 class="mt-3 font-semibold tracking-tight text-primary">Use the guides when you need confidence.</h2>
          <p class="mt-4 text-slate-700 dark:text-slate-300">
            The guide library is where the site becomes useful long term. Each guide is built to answer a real buying or care question in the same practical format.
          </p>
          <div class="mt-6 grid gap-3 md:grid-cols-2">
            <a href="/guides/aquarium-filter-types" class="rounded-[1.4rem] border border-primary/10 bg-light-bg/55 px-5 py-4 transition-colors hover:border-primary/30 hover:bg-white dark:border-white/8 dark:bg-slate-950/70" data-track-click="guide_feature_click" data-track-location="home-guides-panel" data-track-label="Aquarium Filter Types" data-track-category="guides" data-track-destination="/guides/aquarium-filter-types">
              <div class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1">Equipment</div>
              <div class="mt-2 font-semibold text-primary">Aquarium Filter Types</div>
            </a>
            <a href="/guides/beginner-tank-setup" class="rounded-[1.4rem] border border-primary/10 bg-light-bg/55 px-5 py-4 transition-colors hover:border-primary/30 hover:bg-white dark:border-white/8 dark:bg-slate-950/70" data-track-click="guide_feature_click" data-track-location="home-guides-panel" data-track-label="Beginner Tank Setup" data-track-category="guides" data-track-destination="/guides/beginner-tank-setup">
              <div class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1">Setup</div>
              <div class="mt-2 font-semibold text-primary">Beginner Tank Setup</div>
            </a>
            <a href="/guides/freshwater-vs-saltwater" class="rounded-[1.4rem] border border-primary/10 bg-light-bg/55 px-5 py-4 transition-colors hover:border-primary/30 hover:bg-white dark:border-white/8 dark:bg-slate-950/70" data-track-click="guide_feature_click" data-track-location="home-guides-panel" data-track-label="Freshwater vs Saltwater" data-track-category="guides" data-track-destination="/guides/freshwater-vs-saltwater">
              <div class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1">Planning</div>
              <div class="mt-2 font-semibold text-primary">Freshwater vs Saltwater</div>
            </a>
            <a href="/guides" class="rounded-[1.4rem] border border-dashed border-primary/20 bg-transparent px-5 py-4 transition-colors hover:border-primary/35 hover:bg-white/60 dark:hover:bg-slate-950/60" data-track-click="cta_click" data-track-location="home-guides-panel" data-track-label="Browse All Guides" data-track-category="guides" data-track-destination="/guides">
              <div class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1">Library</div>
              <div class="mt-2 font-semibold text-primary">Browse All Guides</div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-8 md:pb-10">
      <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-[1.6rem] border border-primary/10 bg-white/80 px-5 py-5 shadow-[0_18px_55px_-45px_rgba(1,133,174,0.38)] dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Beginner-First</div>
          <p class="mt-3 text-slate-700 dark:text-slate-300">The site is built to reduce overwhelm and turn first-tank questions into a clear next move.</p>
        </div>
        <div class="rounded-[1.6rem] border border-primary/10 bg-white/80 px-5 py-5 shadow-[0_18px_55px_-45px_rgba(1,133,174,0.38)] dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Real Owner</div>
          <p class="mt-3 text-slate-700 dark:text-slate-300">Fin Sanctuary is tied to a real person, a real aquarium hobby, and a direct contact path through the site.</p>
        </div>
        <div class="rounded-[1.6rem] border border-primary/10 bg-white/80 px-5 py-5 shadow-[0_18px_55px_-45px_rgba(1,133,174,0.38)] dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Matched Products</div>
          <p class="mt-3 text-slate-700 dark:text-slate-300">Products and accessories are meant to support a sound tank plan, not interrupt the educational flow.</p>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-2">
      <AdSenseBlock className="shadow-[0_24px_80px_-60px_rgba(1,133,174,0.35)]" label="Advertisement" slot={homeInlineAdSlot} />
    </section>

    <section class="relative overflow-hidden border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.12),rgba(243,239,238,0.58))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.16),rgba(2,6,23,0.96))]">
      <div class="absolute inset-x-0 top-0 h-56 bg-[radial-gradient(circle_at_top,rgba(138,201,171,0.35),transparent_58%)] dark:bg-[radial-gradient(circle_at_top,rgba(138,201,171,0.12),transparent_54%)]"></div>
      <div class="mx-auto grid max-w-6xl gap-10 px-6 py-12 md:py-14 xl:grid-cols-[minmax(0,1.05fr)_28rem] xl:items-end">
        <div class="relative">
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Why It Works</div>
          <h1 class="mt-5 max-w-4xl font-bold tracking-tight text-primary">
            Planning, education, and product decisions should reinforce each other.
          </h1>
          <p class="mt-6 max-w-2xl text-slate-700 dark:text-slate-200">
            The strongest aquarium sites help visitors slow down, make fewer expensive mistakes, and buy gear only after the tank plan makes sense. That is the role Fin Sanctuary is built to fill.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/about" class="inline-flex items-center rounded-full bg-primary px-7 py-4 text-base font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="cta_click" data-track-location="home-trust-section" data-track-label="Meet the Owner" data-track-category="trust" data-track-destination="/about">
              Meet the Owner
            </a>
            <a href="/contact" class="inline-flex items-center rounded-full border border-primary/20 bg-white/75 px-7 py-4 text-base font-semibold text-primary transition-colors hover:bg-primary hover:text-white dark:border-white/10 dark:bg-slate-900/70" data-track-click="cta_click" data-track-location="home-trust-section" data-track-label="Ask a Question" data-track-category="contact" data-track-destination="/contact">
              Ask a Question
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="overflow-hidden rounded-[2.4rem] border border-primary/12 bg-white/80 shadow-[0_38px_120px_-55px_rgba(1,133,174,0.5)] backdrop-blur dark:border-white/10 dark:bg-slate-900/82">
            <div class="aspect-[4/5] bg-[radial-gradient(circle_at_top_left,rgba(13,175,188,0.34),transparent_38%),linear-gradient(135deg,rgba(232,217,191,0.92),rgba(138,201,171,0.64)_42%,rgba(1,133,174,0.26))] p-6 dark:bg-[radial-gradient(circle_at_top_left,rgba(138,201,171,0.2),transparent_32%),linear-gradient(135deg,rgba(15,23,42,0.96),rgba(13,175,188,0.22),rgba(1,133,174,0.18))]">
              <div class="flex h-full flex-col justify-between rounded-[2rem] border border-white/35 bg-white/55 p-6 backdrop-blur dark:border-white/10 dark:bg-slate-950/52">
                <div>
                  <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/80">Fin Sanctuary</div>
                  <h2 class="mt-4 font-semibold tracking-tight text-primary">A faster way to narrow the right setup.</h2>
                  <p class="mt-4 text-slate-700 dark:text-slate-300">
                    Answer a short set of questions and get a practical setup direction with fish recommendations, filter guidance, equipment bundles, stocking plans, and matched guides.
                  </p>
                </div>

                <div class="space-y-3">
                  <div class="rounded-[1.4rem] bg-white/82 px-4 py-4 shadow-lg dark:bg-slate-900/78">
                    <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Tank Path</div>
                    <p class="mt-2 text-slate-700 dark:text-slate-300">10-gallon freshwater community or betta-focused setup</p>
                  </div>
                  <div class="rounded-[1.4rem] bg-white/82 px-4 py-4 shadow-lg dark:bg-slate-900/78">
                    <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Filters + Gear</div>
                    <p class="mt-2 text-slate-700 dark:text-slate-300">Beginner-safe filtration, realistic accessories, and conservative stocking</p>
                  </div>
                  <div class="rounded-[1.4rem] bg-primary px-4 py-4 text-white shadow-lg">
                    <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-white/75">Next Step</div>
                    <p class="mt-2 text-white/90">Read the guide, compare the options, then buy only what matches the plan.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-primary/10 bg-white/55 dark:border-white/8 dark:bg-slate-950/55">
      <div class="mx-auto max-w-6xl px-6 py-10 md:py-12">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
          <div>
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">What This Site Covers</div>
            <h2 class="mt-3 font-semibold tracking-tight text-primary">Everything should point back to a practical home aquarium decision.</h2>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-[1.6rem] border border-primary/10 bg-light-bg/75 p-5 dark:border-white/8 dark:bg-slate-900/70">
              <h3 class="font-semibold text-primary">Fish and Compatibility</h3>
              <p class="mt-3 text-slate-700 dark:text-slate-300">Community fish, bettas, cichlid-style setups, stocking ideas, and fish to avoid mixing.</p>
            </div>
            <div class="rounded-[1.6rem] border border-primary/10 bg-light-bg/75 p-5 dark:border-white/8 dark:bg-slate-900/70">
              <h3 class="font-semibold text-primary">Equipment and Filters</h3>
              <p class="mt-3 text-slate-700 dark:text-slate-300">Filters, heaters, lights, substrate, water testing, and low-maintenance gear choices.</p>
            </div>
            <div class="rounded-[1.6rem] border border-primary/10 bg-light-bg/75 p-5 dark:border-white/8 dark:bg-slate-900/70">
              <h3 class="font-semibold text-primary">Tank Setup and Care</h3>
              <p class="mt-3 text-slate-700 dark:text-slate-300">Cycling, maintenance routines, common beginner mistakes, and office-friendly setups.</p>
            </div>
            <div class="rounded-[1.6rem] border border-primary/10 bg-light-bg/75 p-5 dark:border-white/8 dark:bg-slate-900/70">
              <h3 class="font-semibold text-primary">Accessories and Products</h3>
              <p class="mt-3 text-slate-700 dark:text-slate-300">3D-printed accessories and carefully matched product picks that support useful educational content.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10 md:py-12">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
        <div class="rounded-[2rem] border border-primary/10 bg-white px-7 py-8 dark:border-white/8 dark:bg-slate-900 md:px-8">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Shop + Updates</div>
          <h2 class="mt-3 font-semibold tracking-tight text-primary">Keep research, product questions, and email updates connected.</h2>
          <p class="mt-4 max-w-3xl text-slate-700 dark:text-slate-300">
            Fin Sanctuary should educate first, then make the next step obvious. That includes product-fit questions, practical accessory recommendations, and an email list for new guides, product drops, and useful aquarium updates.
          </p>
          <div class="mt-7 grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.9fr)]">
            <div class="space-y-4">
              <div class="flex flex-wrap gap-4">
                <a href="/shop" class="inline-flex rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="cta_click" data-track-location="home-shop-updates" data-track-label="Visit the Shop" data-track-category="shop" data-track-destination="/shop">Visit the Shop</a>
                <a href="/contact" class="inline-flex rounded-full border border-primary/20 bg-white px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white dark:border-white/10 dark:bg-slate-950/70" data-track-click="cta_click" data-track-location="home-shop-updates" data-track-label="Ask a Question" data-track-category="contact" data-track-destination="/contact">Ask a Question</a>
              </div>
              <p class="text-sm text-slate-600 dark:text-slate-400">Questions about product fit, custom prints, or guide requests can go through the contact page before the storefront and newsletter systems get deeper integrations.</p>
            </div>
            <NewsletterSignupCard
              className="border-primary/10 bg-light-bg/55 dark:bg-slate-950/60"
              title="Email Updates"
              interest="newsletter-homepage"
              location="home-shop-updates"
              description="Join the email list for new guides, 3D-printed accessory updates, and practical aquarium planning notes."
            />
          </div>
        </div>

        <div class="rounded-[2rem] border border-primary/10 bg-[linear-gradient(180deg,rgba(232,217,191,0.55),rgba(255,255,255,0.9))] p-6 dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.12),rgba(15,23,42,0.92))]">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">What You’ll Get</div>
          <ul class="mt-5 space-y-4 text-slate-700 dark:text-slate-300">
            <li>More long-form guides built around real beginner decisions and common maintenance problems.</li>
            <li>Product recommendations that tie back to the guides and the aquarium wizard instead of random shopping lists.</li>
            <li>Videos, tank examples, and practical media that support the written guides.</li>
            <li>Clear commercial disclosures so ads, affiliate links, and products stay transparent.</li>
          </ul>
          <a href="/newsletter" class="mt-6 inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="cta_click" data-track-location="home-updates-card" data-track-label="Open Newsletter Page" data-track-category="newsletter" data-track-destination="/newsletter">
            See Newsletter Details
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
