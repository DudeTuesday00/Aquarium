---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-6xl mx-auto px-6 py-12">
    <h2 class="text-5xl font-bold text-primary mb-4">Welcome to Your Home Aquarium Hub</h2>
    <p class="text-2xl text-accent-2 mb-8">Freshwater • Saltwater • 3D-Printed Accessories • Expert Guides</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-xl">
        <h3 class="text-accent-1 text-3xl mb-4">Start the Wizard</h3>
        <p class="text-warm-neutral">We'll help you choose the perfect tank, fish, and equipment.</p>
      </div>
      <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-xl">
        <h3 class="text-accent-1 text-3xl mb-4">Browse Knowledge Guides</h3>
        <p class="text-warm-neutral">Filters, lighting, diseases, food, and more.</p>
      </div>
    </div>
  </main>
</Layout>