---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Aquarium Wizard • Home Tanks Made Easy"
  description="Start your home aquarium with an interactive setup wizard, beginner-friendly guides, and custom 3D-printed accessories."
>
  <main>
    <!-- Hero Banner -->
    <section class="bg-gradient-to-br from-primary via-accent-1 to-accent-2 text-white py-24">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-6xl md:text-7xl font-bold tracking-tighter mb-6">Your Home Aquarium<br>Starts Here</h1>
        <p class="text-2xl max-w-2xl mx-auto mb-10">The interactive Wizard + expert guides + 3D-printed accessories for freshwater & saltwater tanks</p>
        <div class="flex flex-wrap gap-6 justify-center">
          <a href="/wizard" class="bg-white text-primary px-10 py-5 rounded-3xl text-xl font-semibold hover:bg-accent-1 hover:text-white transition-all">Start the Wizard →</a>
          <a href="/guides" class="border-2 border-white px-10 py-5 rounded-3xl text-xl font-semibold hover:bg-white hover:text-primary transition-all">Browse Guides</a>
        </div>
      </div>
    </section>

    <!-- Quick Links -->
    <section class="max-w-6xl mx-auto px-6 py-16 grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <a href="/wizard" class="group bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-xl hover:shadow-2xl transition-all">
        <div class="text-5xl mb-4">🧙</div>
        <h3 class="text-2xl font-semibold text-primary">Aquarium Wizard</h3>
        <p class="text-warm-neutral mt-3">Get your perfect tank & fish recommendation in 2 minutes</p>
      </a>
      <a href="/guides" class="group bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-xl hover:shadow-2xl transition-all">
        <div class="text-5xl mb-4">📖</div>
        <h3 class="text-2xl font-semibold text-primary">Knowledge Guides</h3>
        <p class="text-warm-neutral mt-3">Filters, lighting, diseases, cycling & more</p>
      </a>
      <a href="/shop" class="group bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-xl hover:shadow-2xl transition-all">
        <div class="text-5xl mb-4">🛠️</div>
        <h3 class="text-2xl font-semibold text-primary">3D-Print Shop</h3>
        <p class="text-warm-neutral mt-3">Filter guards, feeding rings & custom accessories</p>
      </a>
      <a href="/gallery" class="group bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-xl hover:shadow-2xl transition-all">
        <div class="text-5xl mb-4">📸</div>
        <h3 class="text-2xl font-semibold text-primary">Photo Gallery</h3>
        <p class="text-warm-neutral mt-3">Real tanks & accessories in action</p>
      </a>
    </section>

    <!-- Featured Guide Teaser -->
    <section class="bg-light-bg dark:bg-slate-950 py-16">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-4xl font-bold text-primary mb-8 text-center">Featured Guide</h2>
        <a href="/guides/beginner-tank-setup" class="block max-w-2xl mx-auto bg-white dark:bg-slate-900 p-10 rounded-3xl shadow-xl hover:shadow-2xl transition-all">
          <div class="text-accent-1 text-sm font-medium">SETUP & MAINTENANCE</div>
          <h3 class="text-3xl font-semibold text-primary mt-2">Complete Beginner Tank Setup Guide 2026</h3>
          <p class="text-warm-neutral mt-4">Step-by-step guide to cycling your first aquarium and avoiding the #1 beginner mistake</p>
          <div class="mt-8 text-primary font-medium">Read the full guide →</div>
        </a>
      </div>
    </section>
  </main>
</Layout>
