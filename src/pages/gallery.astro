---
import Layout from '../layouts/Layout.astro';
import NewsletterSignupCard from '../components/NewsletterSignupCard.astro';
import { getCollection } from 'astro:content';

const galleryItems = [
  {
    title: 'Freshwater Community Tank',
    note: 'Filter guard in use on a beginner-friendly mixed community setup.',
    accent: 'from-primary via-accent-1 to-accent-2'
  },
  {
    title: 'Planted Freshwater Layout',
    note: 'Plant clips and cleaner hardscape organization for a calmer display.',
    accent: 'from-accent-1 via-accent-2 to-primary'
  },
  {
    title: 'Saltwater Nano Tank',
    note: 'Compact reef-style tank with conservative livestock and feeding control.',
    accent: 'from-accent-2 via-primary to-accent-1'
  }
];

const videos = (await getCollection('videos')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const featuredVideo = videos.find((entry) => entry.data.featured) ?? videos[0];
---

<Layout
  title="Aquarium Gallery • Real Tanks and Accessories"
  description="See example aquarium setups and 3D-printed accessories in use across freshwater, planted, and saltwater home tanks."
  ogImage="/images/og/gallery.svg"
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.08),rgba(243,239,238,0.55))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.14),rgba(2,6,23,0.95))]">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:py-12 xl:grid-cols-[minmax(0,1fr)_22rem] xl:items-end">
        <div>
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Gallery + Video</div>
          <h1 class="mt-5 font-bold tracking-tight text-primary">Real tanks, real accessories, and a growing visual library for the site.</h1>
          <p class="mt-6 max-w-3xl text-slate-700 dark:text-slate-200">
            This page already features live video and is designed to keep growing with more real tank photography, accessory examples, and customer-friendly visual proof across the site.
          </p>
        </div>
        <div class="rounded-[2rem] border border-primary/10 bg-white/80 p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] backdrop-blur dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Current Use</div>
          <ul class="mt-4 space-y-3 text-slate-700 dark:text-slate-300">
            <li>Feature live YouTube content from Fin Sanctuary.</li>
            <li>Show real aquariums and 3D-printed parts in context.</li>
            <li>Support social proof for future product pages and user submissions.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10">
      {featuredVideo && (
        <section class="mb-10 rounded-[2rem] border border-primary/10 bg-white p-6 shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] dark:border-white/8 dark:bg-slate-900 md:p-8">
          <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-center">
            <div>
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Featured Video</div>
              <h2 class="mt-3 font-semibold tracking-tight text-primary">{featuredVideo.data.title}</h2>
              <p class="mt-4 text-slate-700 dark:text-slate-300">{featuredVideo.data.description}</p>
              <div class="mt-5 flex flex-wrap gap-3">
                <a
                  href="/videos"
                  class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1"
                >
                  Browse Video Library
                </a>
                <a
                  href={featuredVideo.data.externalUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
                >
                  Watch on YouTube
                </a>
              </div>
            </div>
            <div class="overflow-hidden rounded-[1.75rem] border border-primary/10 bg-light-bg/60 shadow-[0_20px_70px_-50px_rgba(1,133,174,0.45)] dark:border-white/8 dark:bg-slate-950/70">
              <div class="aspect-video">
                <iframe
                  class="h-full w-full"
                  src={`https://www.youtube.com/embed/${featuredVideo.data.videoId}`}
                  title={featuredVideo.data.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          </div>
        </section>
      )}

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {galleryItems.map((item) => (
          <article class="group overflow-hidden rounded-[2rem] border border-primary/10 bg-white shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] dark:border-white/8 dark:bg-slate-900">
            <div class={`aspect-[4/3] bg-gradient-to-br ${item.accent} p-5`}>
              <div class="flex h-full items-end rounded-[1.5rem] border border-white/20 bg-black/10 p-5 backdrop-blur-sm">
                <div class="max-w-xs rounded-[1.25rem] bg-white/82 px-4 py-4 text-slate-700 shadow-lg dark:bg-slate-950/78 dark:text-slate-200">
                  <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Photo Position</div>
                  <p class="mt-2">This layout is reserved for real tank photography as the gallery grows.</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <h2 class="font-semibold tracking-tight text-primary">{item.title}</h2>
              <p class="mt-3 text-slate-700 dark:text-slate-300">{item.note}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
        <section class="rounded-[2rem] border border-dashed border-primary/20 bg-white/70 px-7 py-6 text-slate-600 dark:border-primary/20 dark:bg-slate-900/75 dark:text-slate-300">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Next Step</div>
          <p class="mt-4">Want your tank featured here later? Use the <a href="/contact" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4">contact page</a> to reach out about future photo and video submissions, then use the guides and video library to keep exploring the educational side of the site.</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/videos" class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1">Browse Videos</a>
            <a href="/guides" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">Browse Guides</a>
          </div>
        </section>
        <NewsletterSignupCard
          interest="newsletter-gallery-page"
          location="gallery-next-step"
          description="Join the email list for new videos, new tank photos, and practical site updates as the gallery grows."
          note="This gives the gallery a clear follow path instead of leaving it as a passive media page."
        />
      </div>
    </section>
  </main>
</Layout>
