---
import Layout from '../layouts/Layout.astro';
import NewsletterSignupCard from '../components/NewsletterSignupCard.astro';
import { getCollection } from 'astro:content';

const videos = (await getCollection('videos')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const featuredVideo = videos.find((entry) => entry.data.featured) ?? videos[0];
---

<Layout
  title="Aquarium Gallery • Real Tanks and Accessories"
  description="See example aquarium setups and 3D-printed accessories in use across freshwater, planted, and saltwater home tanks."
  ogImage="/images/og/gallery.svg"
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.08),rgba(243,239,238,0.55))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.14),rgba(2,6,23,0.95))]">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:py-12 xl:grid-cols-[minmax(0,1fr)_22rem] xl:items-end">
        <div>
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Gallery + Video</div>
          <h1 class="mt-5 font-bold tracking-tight text-primary">Real tanks, real accessories, and useful visual examples.</h1>
          <p class="mt-6 max-w-3xl text-slate-700 dark:text-slate-200">
            This page highlights Fin Sanctuary media that helps visitors see aquariums, accessories, and setup ideas in a more practical visual format.
          </p>
        </div>
        <div class="rounded-[2rem] border border-primary/10 bg-white/80 p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] backdrop-blur dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Current Use</div>
          <ul class="mt-4 space-y-3 text-slate-700 dark:text-slate-300">
            <li>Feature live YouTube content from Fin Sanctuary.</li>
            <li>Show real aquariums and 3D-printed parts in context.</li>
            <li>Support trust with visual proof that ties back to guides and product use.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10">
      {featuredVideo && (
        <section class="mb-10 rounded-[2rem] border border-primary/10 bg-white p-6 shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] dark:border-white/8 dark:bg-slate-900 md:p-8">
          <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-center">
            <div>
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Featured Video</div>
              <h2 class="mt-3 font-semibold tracking-tight text-primary">{featuredVideo.data.title}</h2>
              <p class="mt-4 text-slate-700 dark:text-slate-300">{featuredVideo.data.description}</p>
              <div class="mt-5 flex flex-wrap gap-3">
                <a
                  href="/videos"
                  class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1"
                  data-track-click="media_next_step_click"
                  data-track-location="gallery-featured-video"
                  data-track-label="Browse Video Library"
                  data-track-category="video"
                  data-track-destination="/videos"
                >
                  Browse Video Library
                </a>
                <a
                  href={featuredVideo.data.externalUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
                  data-track-click="video_outbound_click"
                  data-track-location="gallery-featured-video"
                  data-track-label={featuredVideo.data.title}
                  data-track-category="video"
                  data-track-destination={featuredVideo.data.externalUrl}
                >
                  Watch on YouTube
                </a>
              </div>
            </div>
            <div class="overflow-hidden rounded-[1.75rem] border border-primary/10 bg-light-bg/60 shadow-[0_20px_70px_-50px_rgba(1,133,174,0.45)] dark:border-white/8 dark:bg-slate-950/70">
              <div class="aspect-video">
                <iframe
                  class="h-full w-full"
                  src={`https://www.youtube.com/embed/${featuredVideo.data.videoId}`}
                  title={featuredVideo.data.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          </div>
        </section>
      )}

      <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
        <section class="rounded-[2rem] border border-primary/10 bg-white/70 px-7 py-6 text-slate-600 dark:border-white/8 dark:bg-slate-900/75 dark:text-slate-300">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Next Step</div>
          <p class="mt-4">Want to share a tank photo or ask about a featured setup? Use the <a href="/contact" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4" data-track-click="media_next_step_click" data-track-location="gallery-next-step-copy" data-track-label="Contact for Submission" data-track-category="contact" data-track-destination="/contact">contact page</a>, then keep exploring with the guides and video library.</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/videos" class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="media_next_step_click" data-track-location="gallery-next-step" data-track-label="Browse Videos" data-track-category="video" data-track-destination="/videos">Browse Videos</a>
            <a href="/guides" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="media_next_step_click" data-track-location="gallery-next-step" data-track-label="Browse Guides" data-track-category="guides" data-track-destination="/guides">Browse Guides</a>
          </div>
        </section>
        <NewsletterSignupCard
          interest="newsletter-gallery-page"
          location="gallery-next-step"
          description="Join the email list for new videos, new tank photos, and practical site updates."
          note="This keeps the gallery connected to the rest of the site instead of leaving it as a passive media page."
        />
      </div>
    </section>
  </main>
</Layout>
