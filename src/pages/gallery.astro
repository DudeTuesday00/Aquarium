---
import Layout from '../layouts/Layout.astro';

const galleryItems = [
  {
    title: 'Freshwater Community Tank',
    note: 'Filter guard in use on a beginner-friendly mixed community setup.',
    accent: 'from-primary via-accent-1 to-accent-2'
  },
  {
    title: 'Planted Freshwater Layout',
    note: 'Plant clips and cleaner hardscape organization for a calmer display.',
    accent: 'from-accent-1 via-accent-2 to-primary'
  },
  {
    title: 'Saltwater Nano Tank',
    note: 'Compact reef-style tank with conservative livestock and feeding control.',
    accent: 'from-accent-2 via-primary to-accent-1'
  }
];
---

<Layout
  title="Aquarium Gallery • Real Tanks and Accessories"
  description="See example aquarium setups and 3D-printed accessories in use across freshwater, planted, and saltwater home tanks."
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.08),rgba(243,239,238,0.55))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.14),rgba(2,6,23,0.95))]">
      <div class="mx-auto grid max-w-6xl gap-10 px-6 py-14 md:py-18 xl:grid-cols-[minmax(0,1fr)_22rem] xl:items-end">
        <div>
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Photo Gallery</div>
          <h1 class="mt-5 text-5xl font-bold tracking-tight text-primary md:text-6xl">Real tanks, real accessories, and future photo-led storytelling.</h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-700 dark:text-slate-200 md:text-2xl md:leading-9">
            This page is ready for real photography later. For now, it establishes the layout for aquarium showcases, accessory examples, and user submissions.
          </p>
        </div>
        <div class="rounded-[2rem] border border-primary/10 bg-white/80 p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] backdrop-blur dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Planned Use</div>
          <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-700 dark:text-slate-300">
            <li>Show real aquariums and 3D-printed parts in context.</li>
            <li>Support social proof for future product pages.</li>
            <li>Accept user-submitted tanks later through the contact form.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-14">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {galleryItems.map((item) => (
          <article class="group overflow-hidden rounded-[2rem] border border-primary/10 bg-white shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] dark:border-white/8 dark:bg-slate-900">
            <div class={`aspect-[4/3] bg-gradient-to-br ${item.accent} p-5`}>
              <div class="flex h-full items-end rounded-[1.5rem] border border-white/20 bg-black/10 p-5 backdrop-blur-sm">
                <div class="max-w-xs rounded-[1.25rem] bg-white/82 px-4 py-4 text-sm leading-6 text-slate-700 shadow-lg dark:bg-slate-950/78 dark:text-slate-200">
                  <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Image Slot</div>
                  <p class="mt-2">Replace this block with real tank photography later.</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <h2 class="text-2xl font-semibold tracking-tight text-primary">{item.title}</h2>
              <p class="mt-3 text-sm leading-7 text-slate-700 dark:text-slate-300">{item.note}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 rounded-[2rem] border border-dashed border-primary/20 bg-white/70 px-7 py-7 text-center text-sm leading-7 text-slate-600 dark:border-primary/20 dark:bg-slate-900/75 dark:text-slate-300">
        Want your tank featured later? That submission path can run through the contact form once the gallery starts using real photos.
      </div>
    </section>
  </main>
</Layout>
