---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Aquarium Accessories Shop • 3D-Printed Tank Tools"
  description="Browse 3D-printed aquarium accessories including filter guards, feeding rings, and plant clips designed for home and office tanks."
>
  <main class="max-w-6xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold text-primary mb-4">3D-Printed Aquarium Accessories</h1>
    <p class="text-xl text-accent-2 mb-10">Hand-designed in Norman, Oklahoma • Perfect for home & small-office tanks</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <!-- Product 1 -->
      <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-xl overflow-hidden group">
        <div class="h-64 bg-gradient-to-br from-primary to-accent-1 flex items-center justify-center text-white text-6xl">🛡️</div>
        <div class="p-8">
          <h3 class="text-2xl font-semibold text-primary group-hover:text-accent-1 transition-colors">Filter Guard</h3>
          <p class="text-warm-neutral mt-2">Protects fish from intake tubes • Fits 10–55 gallon tanks</p>
          <div class="mt-6 flex justify-between items-end">
            <div>
              <span class="text-3xl font-bold text-primary">$12.99</span>
            </div>
            <a href="https://your-etsy-link.com" 
               class="bg-primary text-white px-8 py-3 rounded-2xl font-medium hover:bg-accent-1 transition-colors">Buy Now</a>
          </div>
        </div>
      </div>

      <!-- Product 2 -->
      <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-xl overflow-hidden group">
        <div class="h-64 bg-gradient-to-br from-accent-1 to-accent-2 flex items-center justify-center text-white text-6xl">🍽️</div>
        <div class="p-8">
          <h3 class="text-2xl font-semibold text-primary group-hover:text-accent-1 transition-colors">Feeding Ring</h3>
          <p class="text-warm-neutral mt-2">Keeps food in one spot • Reduces waste & mess</p>
          <div class="mt-6 flex justify-between items-end">
            <div>
              <span class="text-3xl font-bold text-primary">$8.99</span>
            </div>
            <a href="https://your-etsy-link.com" 
               class="bg-primary text-white px-8 py-3 rounded-2xl font-medium hover:bg-accent-1 transition-colors">Buy Now</a>
          </div>
        </div>
      </div>

      <!-- Product 3 -->
      <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-xl overflow-hidden group">
        <div class="h-64 bg-gradient-to-br from-accent-2 to-primary flex items-center justify-center text-white text-6xl">🌿</div>
        <div class="p-8">
          <h3 class="text-2xl font-semibold text-primary group-hover:text-accent-1 transition-colors">Plant Weight Clips</h3>
          <p class="text-warm-neutral mt-2">Holds live plants in place • Set of 6</p>
          <div class="mt-6 flex justify-between items-end">
            <div>
              <span class="text-3xl font-bold text-primary">$14.99</span>
            </div>
            <a href="https://your-etsy-link.com" 
               class="bg-primary text-white px-8 py-3 rounded-2xl font-medium hover:bg-accent-1 transition-colors">Buy Now</a>
          </div>
        </div>
      </div>

    </div>

    <div class="mt-16 text-center">
      <p class="text-lg text-warm-neutral">More designs coming soon! Want a custom accessory? <a href="/contact" class="text-primary underline">Contact me</a></p>
    </div>
  </main>
</Layout>
