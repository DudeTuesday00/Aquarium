---
import NewsletterSignupCard from '../components/NewsletterSignupCard.astro';
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: 'Filter Guard',
    summary: 'Protects fish from intake tubes and helps make beginner tanks safer.',
    details: 'Planned for common 10 to 55 gallon home aquariums once the Etsy shop opens.',
    accent: 'from-primary/95 via-accent-1 to-accent-2',
    label: 'Planned Etsy Release',
    fit: 'Best for beginner community tanks, smaller fish, and intake protection upgrades.'
  },
  {
    name: 'Feeding Ring',
    summary: 'Keeps floating food in one zone and reduces mess around the tank.',
    details: 'Planned as an easy Etsy accessory for bettas, community tanks, and office aquariums.',
    accent: 'from-accent-1/95 via-primary to-accent-2',
    label: 'Planned Etsy Release',
    fit: 'Best for calmer feeding zones, floating foods, and cleaner surface routines.'
  },
  {
    name: 'Plant Weight Clips',
    summary: 'Helps keep live plants anchored while new roots establish.',
    details: 'Planned for planted freshwater layouts and low-tech aquascapes sold through Etsy.',
    accent: 'from-accent-2/95 via-primary to-accent-1',
    label: 'Planned Etsy Release',
    fit: 'Best for low-tech planted tanks, rescapes, and floating stem control.'
  }
];

const shopSteps = [
  'Use the guides and wizard to confirm what your tank actually needs.',
  'Ask about fit or custom-print options through the contact page.',
  'Follow the newsletter for Etsy launch notices and new accessory drops.'
];
---

<Layout
  title="Aquarium Accessories Shop • Etsy Storefront Coming Soon"
  description="Explore the planned Fin Sanctuary accessory lineup, request custom-fit 3D prints, and follow upcoming aquarium product releases that will be sold through Etsy."
  ogImage="/images/og/shop.svg"
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.1),rgba(243,239,238,0.5))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.14),rgba(2,6,23,0.96))]">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:py-12 xl:grid-cols-[minmax(0,1.05fr)_24rem] xl:items-end">
        <div>
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">3D-Printed Accessories</div>
          <h1 class="mt-5 font-bold tracking-tight text-primary">Practical tank tools, with Etsy as the product path.</h1>
          <p class="mt-6 max-w-3xl text-slate-700 dark:text-slate-200">
            Fin Sanctuary accessories are being organized for a future Etsy storefront. For now, this page works as the product roadmap: what is planned, what each accessory is for, and how to ask about custom prints or fit before live listings are published.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/contact" class="inline-flex rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="shop_interest_click" data-track-location="shop-hero" data-track-label="Request a Custom Print" data-track-category="shop" data-track-destination="/contact">Request a Custom Print</a>
            <a href="/guides" class="inline-flex rounded-full border border-primary/20 bg-white/75 px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white dark:border-white/10 dark:bg-slate-900/70" data-track-click="cta_click" data-track-location="shop-hero" data-track-label="Read the Guides First" data-track-category="guides" data-track-destination="/guides">Read the Guides First</a>
          </div>
        </div>

        <div class="rounded-[2rem] border border-primary/10 bg-white/80 p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] backdrop-blur dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">How Ordering Will Work</div>
          <ul class="mt-5 space-y-4 text-slate-700 dark:text-slate-300">
            <li>Accessories are designed in Norman, Oklahoma for home and small-office tanks.</li>
            <li>When products go live, the public buying path will be Etsy.</li>
            <li>Until then, fit questions and custom-print requests can go through the contact page.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10">
      <section class="mb-8 rounded-[2rem] border border-primary/10 bg-white px-7 py-6 text-slate-600 shadow-[0_24px_80px_-55px_rgba(1,133,174,0.35)] dark:border-white/8 dark:bg-slate-900 dark:text-slate-300">
        <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Current Shop Status</div>
        <h2 class="mt-3 font-semibold tracking-tight text-primary">The storefront is being prepared for Etsy, not direct checkout.</h2>
        <p class="mt-4 max-w-3xl">
          There are no fake buy buttons or fake Etsy links here. Instead, the shop shows the planned accessory lineup, what each item is meant to solve, and the clearest next step if you want to ask about fit, custom prints, or upcoming availability.
        </p>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {shopSteps.map((step, index) => (
            <div class="rounded-[1.4rem] border border-primary/10 bg-light-bg/70 px-5 py-4 dark:border-white/8 dark:bg-slate-950/70">
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-accent-1">Step {index + 1}</div>
              <p class="mt-3 text-slate-700 dark:text-slate-300">{step}</p>
            </div>
          ))}
        </div>
      </section>

      <div class="grid gap-6 lg:grid-cols-3">
        {products.map((product) => (
          <article class="overflow-hidden rounded-[2rem] border border-primary/10 bg-white shadow-[0_24px_80px_-55px_rgba(1,133,174,0.42)] dark:border-white/8 dark:bg-slate-900">
            <div class={`h-64 bg-gradient-to-br ${product.accent} p-6 text-white`}>
              <div class="flex h-full flex-col justify-between rounded-[1.5rem] border border-white/20 bg-white/10 p-5 backdrop-blur-sm">
                <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-white/80">{product.label}</div>
                <div class="font-semibold tracking-tight">{product.name}</div>
              </div>
            </div>
            <div class="p-7">
              <div>
                <div>
                  <h2 class="font-semibold tracking-tight text-primary">{product.name}</h2>
                  <p class="mt-3 text-slate-700 dark:text-slate-300">{product.summary}</p>
                  <p class="mt-2 text-slate-500 dark:text-slate-400">{product.details}</p>
                  <p class="mt-4 text-sm text-slate-600 dark:text-slate-300">{product.fit}</p>
                </div>
              </div>
              <div class="mt-7 flex flex-wrap gap-3">
                <a href="/contact" class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="shop_interest_click" data-track-location="shop-product-card" data-track-label={product.name} data-track-category="shop" data-track-destination="/contact">Ask About Fit or Custom Print</a>
                <a href="/guides" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="cta_click" data-track-location="shop-product-card" data-track-label={`${product.name} guide CTA`} data-track-category="guides" data-track-destination="/guides">Read a Matching Guide</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <section class="rounded-[2rem] border border-primary/10 bg-white px-7 py-6 text-slate-600 dark:border-white/8 dark:bg-slate-900 dark:text-slate-300">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Next Step</div>
          <h2 class="mt-3 font-semibold tracking-tight text-primary">Match the accessory to the tank, not the other way around.</h2>
          <p class="mt-4">Use the guides and the aquarium wizard first, then ask about fit or custom prints through the contact page. When the listings are live, Etsy will be the public ordering path.</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/guides" class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="cta_click" data-track-location="shop-next-step" data-track-label="Browse Guides" data-track-category="guides" data-track-destination="/guides">Browse Guides</a>
            <a href="/contact" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="shop_interest_click" data-track-location="shop-next-step" data-track-label="Ask About Product Fit" data-track-category="shop" data-track-destination="/contact">Ask About Product Fit</a>
          </div>
        </section>
        <section class="rounded-[2rem] border border-primary/10 bg-white px-7 py-6 text-slate-600 dark:border-white/8 dark:bg-slate-900 dark:text-slate-300">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Disclosures</div>
          <p class="mt-4">Fin Sanctuary uses clear commercial disclosures so visitors know when links, ads, or product placements may support the site.</p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/affiliate-disclosure" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">Affiliate Disclosure</a>
            <a href="/advertising-disclosure" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">Advertising Disclosure</a>
          </div>
        </section>
        <NewsletterSignupCard
          interest="newsletter-shop-page"
          description="Join the email list for new accessory releases, custom-print updates, Etsy launch notices, and guide links that explain what to buy and why."
          note="This is the best low-pressure way to follow product drops before the Etsy storefront is live."
        />
      </div>
    </section>
  </main>
</Layout>
