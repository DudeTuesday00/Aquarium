---
import NewsletterSignupCard from '../components/NewsletterSignupCard.astro';
import Layout from '../layouts/Layout.astro';

const newsletterBenefits = [
  'New long-form aquarium guides as they are published',
  'Etsy product releases and 3D-printed accessory drops',
  'Useful beginner-first planning notes and maintenance reminders',
  'Updates on new videos, gallery additions, and site improvements'
];
---

<Layout
  title="Newsletter • Fin Sanctuary Email Updates"
  description="Join the Fin Sanctuary newsletter for new guides, aquarium planning notes, Etsy product releases, and media updates."
>
  <main>
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.08),rgba(243,239,238,0.55))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.14),rgba(2,6,23,0.95))]">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:py-12 xl:grid-cols-[minmax(0,1fr)_22rem] xl:items-end">
        <div>
          <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Newsletter</div>
          <h1 class="mt-5 font-bold tracking-tight text-primary">Join the Fin Sanctuary email list.</h1>
          <p class="mt-6 max-w-3xl text-slate-700 dark:text-slate-200">
            This is the clearest way to follow new guides, Etsy product releases, aquarium-planning notes, and media updates without checking the site manually.
          </p>
        </div>
        <div class="rounded-[2rem] border border-primary/10 bg-white/80 p-6 shadow-[0_28px_90px_-55px_rgba(1,133,174,0.45)] backdrop-blur dark:border-white/8 dark:bg-slate-900/82">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">What You’ll Get</div>
          <ul class="mt-4 space-y-3 text-slate-700 dark:text-slate-300">
            {newsletterBenefits.map((benefit) => (
              <li>{benefit}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
        <NewsletterSignupCard
          className="p-7 md:p-8"
          title="Email Signup"
          interest="newsletter-page"
          location="newsletter-page"
          description="Enter your email once and Fin Sanctuary will send you the most useful updates across guides, products, and media."
          buttonLabel="Join the Newsletter"
          note="You can still use newsletter@finsanctuary.com if you have a direct newsletter-related question."
        />

        <section class="rounded-[2rem] border border-primary/10 bg-white px-7 py-6 text-slate-600 shadow-[0_24px_80px_-55px_rgba(1,133,174,0.35)] dark:border-white/8 dark:bg-slate-900 dark:text-slate-300">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Good Fit For</div>
          <ul class="mt-4 space-y-3">
            <li>Visitors following the guide library over time</li>
            <li>Beginners who want reminders and practical next steps</li>
            <li>Readers who want Etsy product releases and accessory updates</li>
            <li>Readers who want new videos and visual updates</li>
          </ul>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/guides" class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="newsletter_next_step_click" data-track-location="newsletter-page" data-track-label="Browse Guides" data-track-category="guides" data-track-destination="/guides">Browse Guides</a>
            <a href="/wizard" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="newsletter_next_step_click" data-track-location="newsletter-page" data-track-label="Use the Wizard" data-track-category="wizard" data-track-destination="/wizard">Use the Wizard</a>
          </div>
        </section>
      </div>
    </section>
  </main>
</Layout>
