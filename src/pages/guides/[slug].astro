---
import AdSenseBlock from '../../components/AdSenseBlock.astro';
import NewsletterSignupCard from '../../components/NewsletterSignupCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');

  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide }
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);
const allGuides = await getCollection('guides');
const relatedGuides = allGuides
  .filter((entry) => entry.id !== guide.id)
  .filter(
    (entry) =>
      entry.data.category === guide.data.category ||
      entry.data.tags.some((tag) => guide.data.tags.includes(tag))
  )
  .slice(0, 3);
const sectionHeadings = headings.filter((heading) => heading.depth <= 2);
const publishedLabel = guide.data.publishDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
const updatedLabel = guide.data.updatedDate?.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
const heroLayout = guide.data.heroLayout ?? 'balanced';
const heroTitleSize = guide.data.heroTitleSize ?? 'compact';
const heroImageFit = guide.data.heroImageFit ?? 'cover';
const heroImageAspect = guide.data.heroImageAspect ?? 'wide';
const guideInlineAdSlot = import.meta.env.PUBLIC_ADSENSE_GUIDE_INLINE_SLOT;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const guideOgImage = guide.data.heroImage && Astro.site ? new URL(guide.data.heroImage, Astro.site).toString() : undefined;
const shareImage = guideOgImage ?? (Astro.site ? new URL('/images/og/guides.svg', Astro.site).toString() : undefined);
const shareText = `${guide.data.title} | Fin Sanctuary`;
const xShareUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(canonicalUrl)}&text=${encodeURIComponent(shareText)}`;
const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`;
const pinterestShareUrl = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(canonicalUrl)}${shareImage ? `&media=${encodeURIComponent(shareImage)}` : ''}&description=${encodeURIComponent(guide.data.description)}`;
const guideSchema = canonical => ({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.description,
  datePublished: guide.data.publishDate.toISOString(),
  dateModified: (guide.data.updatedDate ?? guide.data.publishDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Diamond Dave'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Fin Sanctuary'
  },
  articleSection: guide.data.category,
  keywords: guide.data.tags,
  image: guideOgImage ? [guideOgImage] : undefined,
  mainEntityOfPage: canonical
});
---

<Layout
  title={`${guide.data.title} • Fin Sanctuary`}
  description={guide.data.description}
  ogType="article"
  ogImage={guideOgImage}
  publishedTime={guide.data.publishDate.toISOString()}
  modifiedTime={(guide.data.updatedDate ?? guide.data.publishDate).toISOString()}
  keywords={guide.data.tags}
  jsonLd={guideSchema(canonicalUrl)}
>
  <main class="bg-light-bg/65 dark:bg-slate-950">
    <section class="border-b border-primary/10 bg-[linear-gradient(180deg,rgba(1,133,174,0.09),rgba(243,239,238,0.4))] dark:bg-[linear-gradient(180deg,rgba(13,175,188,0.16),rgba(2,6,23,0.96))]">
      <div class="mx-auto max-w-6xl px-6 py-8 md:py-10">
        <a href="/guides" class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.22em] text-primary/80 transition-colors hover:text-primary" data-track-click="guide_navigation_click" data-track-location="guide-header" data-track-label="Back to Guides" data-track-category="guides" data-track-destination="/guides">
          <span aria-hidden="true">←</span>
          Back to Guides
        </a>

        <div class={`mt-6 grid gap-8 ${heroLayout === 'balanced' ? 'lg:grid-cols-[minmax(0,1.08fr)_minmax(18rem,0.92fr)] lg:items-start' : 'lg:grid-cols-[minmax(0,1.08fr)_minmax(18rem,0.92fr)] lg:items-start'}`}>
          <div>
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-primary/70">
              <span>{guide.data.category}</span>
              <span>{guide.data.audience === 'beginner' ? 'Beginner Friendly' : 'Growing Hobbyist'}</span>
              {guide.data.affiliateReady && <span>Affiliate Ready</span>}
            </div>
            <h1 class={`mt-5 font-bold tracking-tight text-primary ${heroTitleSize === 'compact' ? 'max-w-3xl' : 'max-w-4xl'}`}>
              {guide.data.title}
            </h1>
            <p class="mt-5 max-w-3xl text-slate-700 dark:text-slate-200">
              {guide.data.description}
            </p>
            <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-600 dark:text-slate-300">
              <span>Published {publishedLabel}</span>
              {updatedLabel && <span>Updated {updatedLabel}</span>}
            </div>
            <p class="mt-4 text-sm text-slate-600 dark:text-slate-300">
              Commercial transparency matters here. See the <a href="/affiliate-disclosure" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4" data-track-click="disclosure_click" data-track-location="guide-header" data-track-label="Affiliate Disclosure" data-track-category="trust" data-track-destination="/affiliate-disclosure">Affiliate Disclosure</a> and <a href="/advertising-disclosure" class="font-semibold text-primary underline decoration-primary/35 underline-offset-4" data-track-click="disclosure_click" data-track-location="guide-header" data-track-label="Advertising Disclosure" data-track-category="trust" data-track-destination="/advertising-disclosure">Advertising Disclosure</a>.
            </p>
          </div>

          {guide.data.heroImage ? (
            <img
              src={guide.data.heroImage}
              alt={guide.data.heroImageAlt || guide.data.title}
              class={`guide-hero-image ${heroLayout === 'balanced' ? 'guide-hero-image-balanced' : ''} ${heroImageFit === 'contain' ? 'object-contain' : 'object-cover'} ${heroImageAspect === 'square' ? 'guide-hero-square' : 'guide-hero-wide'}`}
              loading="eager"
            />
          ) : (
            <div class={`guide-hero-panel ${heroLayout === 'balanced' ? 'guide-hero-image-balanced' : ''} ${heroImageAspect === 'square' ? 'guide-hero-square' : 'guide-hero-wide'}`}>
              <div class="guide-hero-panel-inner">
                <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/80">Guide Image Coming Soon</div>
                <p class="mt-3 text-slate-700 dark:text-slate-200">This guide already uses the standard split text-and-image header, and official artwork can drop in here later without changing the page layout.</p>
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-8 md:py-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem] lg:gap-10">
        <article class="min-w-0">
          <div class="rounded-[2rem] border border-primary/10 bg-white px-6 py-6 shadow-[0_24px_80px_-50px_rgba(1,133,174,0.35)] dark:border-white/8 dark:bg-slate-900 md:px-8 md:py-8">
            <div class="guide-content">
              <Content />
            </div>
          </div>

          <AdSenseBlock className="mt-8" label="Advertisement" slot={guideInlineAdSlot} />

          <section class="mt-8 rounded-[2rem] border border-primary/10 bg-white px-6 py-6 shadow-[0_18px_55px_-45px_rgba(1,133,174,0.35)] dark:border-white/8 dark:bg-slate-900 md:px-8">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Next Step</div>
            <h2 class="mt-3 font-semibold tracking-tight text-primary">Keep moving from reading to action.</h2>
            <p class="mt-4 text-slate-700 dark:text-slate-300">Use the related guides to go deeper, check the shop if you need matching accessories, or join the email list if you want future guides and product updates.</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href="/guides" class="inline-flex rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-1" data-track-click="guide_next_step_click" data-track-location="guide-next-step" data-track-label="Browse More Guides" data-track-category="guides" data-track-destination="/guides">Browse More Guides</a>
              <a href="/shop" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="guide_next_step_click" data-track-location="guide-next-step" data-track-label="Shop Matching Accessories" data-track-category="shop" data-track-destination="/shop">Shop Matching Accessories</a>
              <a href="/contact" class="inline-flex rounded-full border border-primary/20 px-5 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white" data-track-click="guide_next_step_click" data-track-location="guide-next-step" data-track-label="Ask a Question" data-track-category="contact" data-track-destination="/contact">Ask a Question</a>
            </div>
          </section>

          <NewsletterSignupCard
            className="mt-6"
            interest={`newsletter-guide-${guide.id}`}
            location="guide-page"
            description="Get new guides, product updates, and practical aquarium planning notes by email without waiting to check back manually."
            note="Use the contact page if you want direct help instead of general email updates."
          />

          {relatedGuides.length > 0 && (
            <section class="mt-10">
              <div class="mb-6 flex items-end justify-between gap-4">
                <div>
                  <div class="text-xs font-semibold uppercase tracking-[0.24em] text-primary/75">Read Next</div>
                  <h2 class="mt-2 font-semibold tracking-tight text-primary">Related Guides</h2>
                </div>
              </div>
              <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
                {relatedGuides.map((entry) => (
                  <a href={`/guides/${entry.id}`} class="group rounded-[1.75rem] border border-primary/10 bg-white p-6 transition-transform duration-200 hover:-translate-y-1 hover:border-primary/30 dark:border-white/8 dark:bg-slate-900" data-track-click="guide_related_click" data-track-location="guide-related" data-track-label={entry.data.title} data-track-category="guides" data-track-destination={`/guides/${entry.id}`}>
                    <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-accent-1">{entry.data.category}</div>
                    <h3 class="mt-3 font-semibold tracking-tight text-primary transition-colors group-hover:text-accent-1">{entry.data.title}</h3>
                    <p class="mt-3 text-slate-600 dark:text-slate-300">{entry.data.description}</p>
                    <div class="mt-5 text-sm font-medium text-primary">Open guide →</div>
                  </a>
                ))}
              </div>
            </section>
          )}
        </article>

        <aside class="space-y-6 lg:sticky lg:top-28 lg:self-start">
          <section class="rounded-[1.75rem] border border-primary/10 bg-white p-6 shadow-[0_18px_50px_-40px_rgba(1,133,174,0.45)] dark:border-white/8 dark:bg-slate-900">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Quick Facts</div>
            <dl class="mt-4 space-y-4 text-slate-600 dark:text-slate-300">
              <div>
                <dt class="font-semibold text-primary">Category</dt>
                <dd>{guide.data.category}</dd>
              </div>
              <div>
                <dt class="font-semibold text-primary">Audience</dt>
                <dd>{guide.data.audience === 'beginner' ? 'Beginner-friendly guidance' : 'For growing hobbyists'}</dd>
              </div>
              <div>
                <dt class="font-semibold text-primary">Published</dt>
                <dd>{publishedLabel}</dd>
              </div>
              {updatedLabel && (
                <div>
                  <dt class="font-semibold text-primary">Updated</dt>
                  <dd>{updatedLabel}</dd>
                </div>
              )}
            </dl>
          </section>

          <section class="rounded-[1.75rem] border border-primary/10 bg-white p-6 dark:border-white/8 dark:bg-slate-900">
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Share This Guide</div>
            <p class="mt-4 text-sm text-slate-600 dark:text-slate-300">Share long-form aquarium advice to X, Facebook, Pinterest, or copy the link for Instagram posts and stories.</p>
            <div class="mt-5 grid grid-cols-2 gap-3">
              <a
                href={xShareUrl}
                target="_blank"
                rel="noreferrer"
                class="guide-share-icon"
                aria-label="Share on X"
                title="Share on X"
                data-track-click="guide_share_click"
                data-track-location="guide-share"
                data-track-label="X"
                data-track-category="social"
                data-track-destination={xShareUrl}
              >
                <img src="/images/social/twitter-x.png" alt="" class="guide-share-icon-image" loading="lazy" />
                <span class="sr-only">Share on X</span>
              </a>
              <a
                href={facebookShareUrl}
                target="_blank"
                rel="noreferrer"
                class="guide-share-icon"
                aria-label="Share on Facebook"
                title="Share on Facebook"
                data-track-click="guide_share_click"
                data-track-location="guide-share"
                data-track-label="Facebook"
                data-track-category="social"
                data-track-destination={facebookShareUrl}
              >
                <img src="/images/social/facebook-icon.png" alt="" class="guide-share-icon-image" loading="lazy" />
                <span class="sr-only">Share on Facebook</span>
              </a>
              <a
                href={pinterestShareUrl}
                target="_blank"
                rel="noreferrer"
                class="guide-share-icon"
                aria-label="Share on Pinterest"
                title="Share on Pinterest"
                data-track-click="guide_share_click"
                data-track-location="guide-share"
                data-track-label="Pinterest"
                data-track-category="social"
                data-track-destination={pinterestShareUrl}
              >
                <img src="/images/social/pinterest-logo.png" alt="" class="guide-share-icon-image" loading="lazy" />
                <span class="sr-only">Share on Pinterest</span>
              </a>
              <button
                type="button"
                class="guide-share-copy guide-share-icon"
                aria-label="Copy guide link for Instagram"
                title="Copy guide link for Instagram"
                data-track-click="guide_share_click"
                data-track-location="guide-share"
                data-track-label="Instagram Copy Link"
                data-track-category="social"
                data-track-destination={canonicalUrl}
                data-copy-url={canonicalUrl}
              >
                <img src="/images/social/instagram-logo.png" alt="" class="guide-share-icon-image" loading="lazy" />
                <span class="sr-only">Copy guide link for Instagram</span>
              </button>
            </div>
            <p class="guide-share-feedback mt-4 min-h-[1.25rem] text-xs font-medium uppercase tracking-[0.18em] text-accent-1" aria-live="polite"></p>
          </section>

          {sectionHeadings.length > 0 && (
            <section class="rounded-[1.75rem] border border-primary/10 bg-white p-6 dark:border-white/8 dark:bg-slate-900">
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">On This Page</div>
              <nav class="mt-4">
                <ul class="space-y-3 text-slate-600 dark:text-slate-300">
                  {sectionHeadings.map((heading) => (
                    <li>
                      <a href={`#${heading.slug}`} class={`block transition-colors hover:text-primary ${heading.depth === 1 ? 'font-semibold text-primary' : 'pl-3'}`}>
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </section>
          )}

          {guide.data.tags.length > 0 && (
            <section class="rounded-[1.75rem] border border-primary/10 bg-white p-6 dark:border-white/8 dark:bg-slate-900">
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-primary/75">Topics</div>
              <div class="mt-4 flex flex-wrap gap-2">
                {guide.data.tags.map((tag) => (
                  <span class="rounded-full border border-primary/15 px-3 py-1 text-xs font-medium uppercase tracking-[0.14em] text-primary/85 dark:border-primary/25">
                    {tag}
                  </span>
                ))}
              </div>
            </section>
          )}
        </aside>
      </div>
    </section>
  </main>
</Layout>

<script>
  const copyButton = document.querySelector('.guide-share-copy');
  const copyFeedback = document.querySelector('.guide-share-feedback');

  copyButton?.addEventListener('click', async () => {
    const url = copyButton.dataset.copyUrl;
    if (!url) return;

    try {
      await navigator.clipboard.writeText(url);
      if (copyFeedback) {
        copyFeedback.textContent = 'Link copied for Instagram sharing';
      }
    } catch {
      if (copyFeedback) {
        copyFeedback.textContent = 'Copy failed, but the guide URL is in the address bar';
      }
    }
  });
</script>

<style>
  .guide-hero-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 2rem;
    object-position: center;
    background: rgba(255, 255, 255, 0.82);
  }

  .guide-hero-image-balanced {
    max-width: 32rem;
    justify-self: end;
  }

  .guide-hero-square {
    width: min(100%, 494px);
    aspect-ratio: 1 / 1;
  }

  .guide-hero-wide {
    aspect-ratio: 5 / 4;
  }

  .guide-hero-panel {
    width: 100%;
    overflow: hidden;
    border-radius: 2rem;
    border: 1px solid rgba(1, 133, 174, 0.15);
    background:
      radial-gradient(circle at top left, rgba(13, 175, 188, 0.18), transparent 46%),
      linear-gradient(135deg, rgba(243, 239, 238, 0.95), rgba(138, 201, 171, 0.46) 52%, rgba(1, 133, 174, 0.14));
    box-shadow: 0 30px 80px -40px rgba(1, 133, 174, 0.35);
  }

  .guide-hero-panel-inner {
    display: flex;
    height: 100%;
    min-height: 100%;
    align-items: flex-end;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
  }

  :global(.dark) .guide-hero-image {
    background: rgba(15, 23, 42, 0.88);
  }

  :global(.dark) .guide-hero-panel {
    border-color: rgba(255, 255, 255, 0.1);
    background:
      radial-gradient(circle at top left, rgba(138, 201, 171, 0.16), transparent 42%),
      linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(13, 175, 188, 0.2), rgba(1, 133, 174, 0.16));
  }

  .guide-content :global(h1) {
    display: none;
  }

  .guide-content :global(h2),
  .guide-content :global(h3),
  .guide-content :global(h4) {
    color: var(--color-primary);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .guide-content :global(h2) {
    margin-top: 3.5rem;
    margin-bottom: 1rem;
    font-size: 32px;
    line-height: 1.6;
  }

  .guide-content :global(h3) {
    margin-top: 2.5rem;
    margin-bottom: 0.85rem;
    font-size: 26px;
    line-height: 1.6;
  }

  .guide-content :global(h4) {
    margin-top: 1.8rem;
    margin-bottom: 0.65rem;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .guide-content :global(p),
  .guide-content :global(li) {
    color: rgb(51 65 85);
    font-size: 18px;
    line-height: 1.6;
  }

  :global(.dark) .guide-content :global(p),
  :global(.dark) .guide-content :global(li) {
    color: rgb(226 232 240);
  }

  .guide-content :global(p + p) {
    margin-top: 1.15rem;
  }

  .guide-content :global(ul),
  .guide-content :global(ol) {
    margin: 1.15rem 0 1.5rem;
    padding-left: 1.4rem;
  }

  .guide-content :global(li + li) {
    margin-top: 0.55rem;
  }

  .guide-content :global(table) {
    width: 100%;
    margin: 1.8rem 0 2.2rem;
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    border: 1px solid rgba(1, 133, 174, 0.12);
    border-radius: 1.25rem;
    background: rgba(243, 239, 238, 0.5);
    font-size: 0.98rem;
  }

  :global(.dark) .guide-content :global(table) {
    background: rgba(15, 23, 42, 0.65);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .guide-content :global(thead) {
    background: rgba(1, 133, 174, 0.1);
  }

  :global(.dark) .guide-content :global(thead) {
    background: rgba(13, 175, 188, 0.16);
  }

  .guide-content :global(th),
  .guide-content :global(td) {
    padding: 1rem 1.1rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid rgba(1, 133, 174, 0.08);
  }

  :global(.dark) .guide-content :global(th),
  :global(.dark) .guide-content :global(td) {
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .guide-content :global(tr:last-child td) {
    border-bottom: 0;
  }

  .guide-content :global(th) {
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .guide-content :global(strong) {
    color: var(--color-primary);
  }

  .guide-content :global(blockquote) {
    margin: 2rem 0;
    border-left: 4px solid rgba(13, 175, 188, 0.55);
    padding: 0.35rem 0 0.35rem 1.25rem;
    color: rgb(15 23 42);
    font-style: italic;
  }

  :global(.dark) .guide-content :global(blockquote) {
    color: rgb(226 232 240);
  }

  .guide-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  .guide-content :global(hr) {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px dashed rgba(1, 133, 174, 0.24);
  }

  .guide-share-icon {
    display: inline-flex;
    min-height: 4.5rem;
    min-width: 4.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 1.25rem;
    border: 1px solid rgba(1, 133, 174, 0.16);
    background: #ffffff;
    padding: 0.85rem;
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
    box-shadow: 0 14px 34px -28px rgba(1, 133, 174, 0.42);
  }

  .guide-share-icon:hover {
    transform: translateY(-1px);
    border-color: rgba(1, 133, 174, 0.36);
    box-shadow: 0 18px 42px -28px rgba(1, 133, 174, 0.5);
  }

  .guide-share-icon-image {
    width: 2.5rem;
    height: 2.5rem;
    object-fit: contain;
    display: block;
  }

  :global(.dark) .guide-share-icon {
    border-color: rgba(255, 255, 255, 0.1);
    background: #ffffff;
  }

  @media (max-width: 768px) {
    .guide-hero-image {
      max-width: none;
    }

    .guide-content :global(p),
    .guide-content :global(li) {
      font-size: 18px;
      line-height: 1.6;
    }

    .guide-content :global(table) {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>
