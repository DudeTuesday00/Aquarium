---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Fin Sanctuary • Home Tanks Made Easy',
  description = 'Fin Sanctuary offers aquarium planning tools, expert guides, 3D-printed accessories, and practical knowledge for home and small-office tanks.',
  ogImage,
  ogType = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  keywords = [],
  jsonLd = []
} = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const defaultOgImage = Astro.site ? new URL('/images/home/fin-sanctuary.png', Astro.site).toString() : undefined;
const resolvedOgImage = ogImage ?? defaultOgImage;
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const siteSchemas = Astro.site
  ? [
      {
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Fin Sanctuary',
        url: Astro.site.toString(),
        logo: new URL('/images/home/fin-sanctuary.png', Astro.site).toString(),
        contactPoint: [
          {
            '@type': 'ContactPoint',
            email: 'info@finsanctuary.com',
            contactType: 'customer support'
          }
        ]
      },
      {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Fin Sanctuary',
        url: Astro.site.toString()
      }
    ]
  : [];
const pageSchemas = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const combinedSchemas = [...siteSchemas, ...pageSchemas];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:site_name" content="Fin Sanctuary" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    {resolvedOgImage && <meta property="og:image:alt" content={title} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content={resolvedOgImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    <meta name="theme-color" content="#0185AE" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {gaMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script is:inline define:vars={{ gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          window.gtag = window.gtag || gtag;
          gtag('js', new Date());
          gtag('config', gaMeasurementId);
        </script>
      </>
    )}
    <meta name="google-adsense-account" content="ca-pub-2083020536499662" />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2083020536499662"
      crossorigin="anonymous"
    ></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
    {combinedSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="min-h-screen bg-light-bg text-slate-950 dark:bg-slate-950 dark:text-white font-sans flex flex-col">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute inset-x-0 top-0 h-[34rem] bg-[radial-gradient(circle_at_top,rgba(13,175,188,0.18),transparent_58%)] dark:bg-[radial-gradient(circle_at_top,rgba(13,175,188,0.14),transparent_54%)]"></div>
      <div class="absolute left-[-8rem] top-32 h-72 w-72 rounded-full bg-primary/8 blur-3xl dark:bg-primary/10"></div>
      <div class="absolute bottom-0 right-[-8rem] h-80 w-80 rounded-full bg-accent-2/12 blur-3xl dark:bg-accent-2/10"></div>
    </div>

    <header class="sticky top-0 z-50 border-b border-primary/10 bg-white/78 backdrop-blur-xl dark:border-white/8 dark:bg-slate-950/78">
      <div class="mx-auto max-w-6xl px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <a href="/" class="min-w-0">
            <img
              src="/images/home/fin-sanctuary.png"
              alt="The Fin Sanctuary Home Aquarium Planning"
              class="h-auto w-[16rem] max-w-full rounded-[0.9rem]"
              loading="eager"
            />
          </a>

          <nav class="hidden items-center gap-2 rounded-full border border-primary/10 bg-white/75 p-1 shadow-[0_18px_40px_-30px_rgba(1,133,174,0.45)] dark:border-white/8 dark:bg-slate-900/75 lg:flex">
            <a href="/" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">Home</a>
            <a href="/start-here" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">Start Here</a>
            <a href="/wizard" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">Wizard</a>
            <a href="/guides" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">Guides</a>
            <a href="/videos" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">Videos</a>
            <a href="/shop" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">Shop</a>
            <a href="/gallery" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">Gallery</a>
            <a href="/about" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">About</a>
            <a href="/contact" class="rounded-full px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:bg-primary hover:text-white dark:text-slate-200">Contact</a>
          </nav>

          <div class="flex items-center gap-3">
            <button
              id="theme-toggle"
              class="hidden rounded-full border border-primary/15 bg-white/80 px-4 py-2 text-sm font-medium text-primary transition-colors hover:bg-primary hover:text-white dark:border-white/10 dark:bg-slate-900/80 md:inline-flex"
              type="button"
            >
              Dark Mode
            </button>
            <button
              id="mobile-menu-btn"
              class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-primary/15 bg-white/80 text-primary transition-colors hover:bg-primary hover:text-white dark:border-white/10 dark:bg-slate-900/80 lg:hidden"
              type="button"
              aria-expanded="false"
              aria-controls="mobile-menu"
              aria-label="Toggle navigation"
            >
              <span class="text-xl leading-none">☰</span>
            </button>
          </div>
        </div>

        <nav id="mobile-menu" class="hidden border-t border-primary/10 pt-4 mt-4 lg:hidden dark:border-white/8">
          <div class="grid gap-2">
            <a href="/" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">Home</a>
            <a href="/start-here" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">Start Here</a>
            <a href="/wizard" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">Wizard</a>
            <a href="/guides" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">Guides</a>
            <a href="/videos" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">Videos</a>
            <a href="/shop" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">Shop</a>
            <a href="/gallery" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">Gallery</a>
            <a href="/about" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">About</a>
            <a href="/contact" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition-colors hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-900">Contact</a>
            <button
              id="theme-toggle-mobile"
              class="mt-2 rounded-2xl border border-primary/15 bg-white/75 px-4 py-3 text-left text-sm font-medium text-primary transition-colors hover:bg-primary hover:text-white dark:border-white/10 dark:bg-slate-900/80"
              type="button"
            >
              Dark Mode
            </button>
          </div>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="mt-auto border-t border-primary/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.2),rgba(232,217,191,0.38))] dark:border-white/8 dark:bg-[linear-gradient(180deg,rgba(2,6,23,0.72),rgba(15,23,42,0.96))]">
      <div class="mx-auto max-w-6xl px-6 py-10">
        <div class="grid gap-10 md:grid-cols-[1.2fr_0.8fr_0.8fr]">
          <div>
            <div class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-primary/75">Fin Sanctuary</div>
            <h2 class="mt-3 font-bold tracking-tight text-primary">Home aquarium planning, guides, and custom accessories.</h2>
            <p class="mt-4 max-w-xl text-slate-600 dark:text-slate-300">
              Built for home and small-office aquarium owners in the USA. Use the wizard to narrow your setup, read long-form guides, and shop 3D-printed accessories designed for practical daily tank care.
            </p>
          </div>

          <div>
            <div class="text-sm font-semibold uppercase tracking-[0.2em] text-primary/75">Explore</div>
            <div class="mt-4 grid gap-3 text-sm">
              <a href="/wizard" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Aquarium Wizard</a>
              <a href="/start-here" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Start Here</a>
              <a href="/guides" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Knowledge Guides</a>
              <a href="/videos" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Videos</a>
              <a href="/newsletter" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Newsletter</a>
              <a href="/shop" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">3D-Printed Accessories</a>
              <a href="/gallery" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Gallery</a>
            </div>
          </div>

          <div>
            <div class="text-sm font-semibold uppercase tracking-[0.2em] text-primary/75">Business</div>
            <div class="mt-4 grid gap-3 text-sm">
              <a href="/about" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">About Me</a>
              <a href="/contact" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Contact</a>
              <a href="/affiliate-disclosure" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Affiliate Disclosure</a>
              <a href="/advertising-disclosure" class="text-slate-700 transition-colors hover:text-primary dark:text-slate-200">Advertising Disclosure</a>
            </div>
          </div>
        </div>

        <div class="mt-10 border-t border-primary/10 pt-6 dark:border-white/8">
          <div class="flex flex-wrap gap-x-5 gap-y-2 text-xs font-medium text-slate-500 dark:text-slate-400">
            <a href="/privacy-policy" class="transition-colors hover:text-primary">Privacy Policy</a>
            <a href="/terms-of-use" class="transition-colors hover:text-primary">Terms of Use</a>
            <a href="/affiliate-disclosure" class="transition-colors hover:text-primary">Affiliate Disclosure</a>
            <a href="/advertising-disclosure" class="transition-colors hover:text-primary">Advertising Disclosure</a>
          </div>
          <div class="mt-4 flex flex-col gap-3 text-xs text-slate-500 dark:text-slate-400 md:flex-row md:items-center md:justify-between">
            <p>© 2026 Fin Sanctuary • finsanctuary.com • Norman, Oklahoma • Built for home aquarium enthusiasts</p>
            <p>Educational content first, with clear disclosures and practical help for home aquarium owners.</p>
          </div>
        </div>
      </div>
    </footer>

    <script>
      window.finTrack = window.finTrack || ((eventName, params = {}) => {
        const payload = { ...params, page_path: window.location.pathname };
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: eventName, ...payload });
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, payload);
        }
      });

      const themeButtons = [document.getElementById('theme-toggle'), document.getElementById('theme-toggle-mobile')].filter(Boolean);
      const html = document.documentElement;

      function syncThemeButtons() {
        const label = html.classList.contains('dark') ? 'Light Mode' : 'Dark Mode';
        themeButtons.forEach((button) => {
          button.textContent = label;
        });
      }

      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        html.classList.add('dark');
      }
      syncThemeButtons();

      themeButtons.forEach((button) => {
        button.addEventListener('click', () => {
          html.classList.toggle('dark');
          localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light';
          syncThemeButtons();
        });
      });

      const mobileBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      mobileBtn?.addEventListener('click', () => {
        const expanded = mobileBtn.getAttribute('aria-expanded') === 'true';
        mobileBtn.setAttribute('aria-expanded', String(!expanded));
        mobileMenu.classList.toggle('hidden');
      });

      document.addEventListener('click', (event) => {
        const trackTarget = event.target.closest('[data-track-click]');
        if (!trackTarget) return;

        const { trackClick, trackLocation, trackLabel, trackCategory, trackInterest, trackDestination } = trackTarget.dataset;
        window.finTrack(trackClick, {
          location: trackLocation,
          label: trackLabel,
          category: trackCategory,
          interest: trackInterest,
          destination: trackDestination
        });
      });

      document.addEventListener('submit', (event) => {
        const form = event.target.closest('form[data-track-submit]');
        if (!form) return;

        const { trackSubmit, trackLocation, trackLabel, trackCategory, trackInterest } = form.dataset;
        window.finTrack(trackSubmit, {
          location: trackLocation,
          label: trackLabel,
          category: trackCategory,
          interest: trackInterest
        });
      });
    </script>
  </body>
</html>
