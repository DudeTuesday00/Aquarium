---
interface Props {
  slot?: string;
  label?: string;
  className?: string;
}

const {
  slot,
  label = 'Advertisement',
  className = ''
} = Astro.props as Props;

const adClient = 'ca-pub-2083020536499662';
const hasSlot = Boolean(slot);
---

{hasSlot && (
  <div class:list={['adsense-block', className]}>
    <div class="adsense-block__label">{label}</div>
    <ins
      class="adsbygoogle adsense-block__unit"
      style="display:block"
      data-ad-client={adClient}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}

<style>
  .adsense-block {
    border-radius: 2rem;
    border: 1px dashed rgba(1, 133, 174, 0.25);
    background: rgba(255, 255, 255, 0.82);
    padding: 1.5rem;
    text-align: center;
  }

  .adsense-block__label {
    margin-bottom: 0.9rem;
    color: rgba(1, 133, 174, 0.78);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .adsense-block__unit {
    min-height: 120px;
  }

  :global(.dark) .adsense-block {
    border-color: rgba(13, 175, 188, 0.2);
    background: rgba(15, 23, 42, 0.82);
  }
</style>
